# ============================================================
# Störungsmelder LZ Frechen – Umgebungsvariablen
# Kopieren als .env und Werte anpassen
# ============================================================

# --- App --------------------------------------------------------
NODE_ENV=production
PORT=3000

# Basis-URL der App (wird in E-Mails als Link verwendet)
APP_BASE_URL=https://werkstatt.lz-frechen.de

# Session-Geheimnis – langer zufälliger String, BITTE ÄNDERN!
SESSION_SECRET=bitte-einen-langen-zufaelligen-string-einsetzen

# --- Fahrzeuge (kommagetrennt) ----------------------------------
VEHICLES=LF10,HLF20,TLF3000,DLA23,ELW1,MTF

# --- Datenbank --------------------------------------------------
# Pfad zur SQLite-Datei (Standard: data/stoerungen.db)
# DB_PATH=/var/data/stoerungen.db

# --- Upload / Speicher ------------------------------------------
# Max. Größe pro Datei in MB (Standard: 8)
MAX_UPLOAD_MB=8

# Upload-Ordner-Limit in MB, bei Überschreitung werden älteste Dateien gelöscht
# Standard: 5120 = 5 GB
MAX_UPLOAD_DIR_MB=5120

# Nach wie vielen Tagen werden Bilder erledigter Störungen komprimiert (Standard: 7)
COMPRESS_AFTER_DAYS=7

# --- E-Mail (SMTP) ----------------------------------------------
# SMTP-Server (z.B. smtp.gmail.com, mail.your-server.de, smtp.office365.com)
MAIL_HOST=smtp.your-server.de

# SMTP-Port: 587 = STARTTLS (empfohlen), 465 = SSL, 25 = unverschlüsselt
MAIL_PORT=587

# true = SSL/TLS direkt (Port 465), false = STARTTLS (Port 587)
MAIL_SECURE=false

# SMTP-Login
MAIL_USER=stoerung@lz-frechen.de
MAIL_PASS=dein-smtp-passwort

# Absender-Adresse (falls abweichend von MAIL_USER)
MAIL_FROM=Störungsmelder LZ Frechen <stoerung@lz-frechen.de>

# Empfänger der Benachrichtigungs-Mails (kommagetrennt)
MAIL_RECIPIENTS=werkstatt@lz-frechen.de,wehrfuehrer@lz-frechen.de
