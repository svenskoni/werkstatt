# ============================================================
# Störungsmelder LZ Frechen – Umgebungsvariablen
# Kopieren als .env und alle Werte anpassen
# Die App startet NICHT wenn eine dieser Variablen fehlt.
# ============================================================

# --- App --------------------------------------------------------
NODE_ENV=production
APP_BASE_URL=https://werkstatt.lz-frechen.de
SESSION_SECRET=bitte-einen-langen-zufaelligen-string-einsetzen

# --- Fahrzeuge (kommagetrennt, keine Leerzeichen) ---------------
VEHICLES=LF10,HLF20,TLF3000,DLA23,ELW1,MTF

# --- Benutzerkonten ---------------------------------------------
# Hashes generieren: node tools/generate-passwords.js
USER_USER_NAME=benutzer
USER_USER_PASS_HASH=$2a$12$...

USER_ADMIN_NAME=admin
USER_ADMIN_PASS_HASH=$2a$12$...

# --- Datenbank --------------------------------------------------
# DB_PATH=/var/data/stoerungen.db

# --- Upload / Speicher ------------------------------------------
MAX_UPLOAD_MB=8
MAX_UPLOAD_DIR_MB=5120
COMPRESS_AFTER_DAYS=7

# --- E-Mail (SMTP) ----------------------------------------------
MAIL_HOST=smtp.your-server.de
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=stoerung@lz-frechen.de
MAIL_PASS=dein-smtp-passwort
MAIL_FROM=Störungsmelder LZ Frechen <stoerung@lz-frechen.de>
MAIL_RECIPIENTS=werkstatt@lz-frechen.de,wehrfuehrer@lz-frechen.de
