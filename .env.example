# =============================================================
# Feuerwehr Störungsmelder – Konfiguration
# Domain: werkstatt.lz-frechen.de
# =============================================================
# Werte in Plesk als Umgebungsvariablen eintragen – NICHT als .env Datei!
# NIEMALS .env committen!

# --- Server ---------------------------------------------------
NODE_ENV=production
APP_BASE_URL=https://werkstatt.lz-frechen.de
# PORT wird von Plesk automatisch gesetzt – NICHT eintragen!

# --- Session --------------------------------------------------
# Generieren: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=HIER_MINDESTENS_48_ZUFAELLIGE_ZEICHEN

# --- Datenbank (SQLite) ---------------------------------------
DB_PATH=./data/stoerungen.db

# --- Upload ---------------------------------------------------
MAX_UPLOAD_MB=8

# --- Fahrzeuge (Komma-getrennt) -------------------------------
VEHICLES=LF10,HLF20,TLF3000,DLA23,ELW1,GW-L2,RTW,KTW,MTF,SW2000

# --- Mail Server ----------------------------------------------
MAIL_HOST=mail.lz-frechen.de
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=stoerung@lz-frechen.de
MAIL_PASS=DEIN_MAIL_PASSWORT
MAIL_FROM="Feuerwehr Störungsmelder <stoerung@lz-frechen.de>"
MAIL_RECIPIENTS=werkstatt@lz-frechen.de,leitung@lz-frechen.de

# --- Benutzerkonten -------------------------------------------
# Hashes generieren: node tools/generate-passwords.js
USER_VIEW_NAME=viewer
USER_VIEW_PASS_HASH=$2a$12$HIER_BCRYPT_HASH_VOM_GENERATOR

USER_USER_NAME=benutzer
USER_USER_PASS_HASH=$2a$12$HIER_BCRYPT_HASH_VOM_GENERATOR

USER_ADMIN_NAME=admin
USER_ADMIN_PASS_HASH=$2a$12$HIER_BCRYPT_HASH_VOM_GENERATOR
