# === App ===
NODE_ENV=production
SESSION_SECRET=bitte-sicheres-geheimnis-setzen
APP_BASE_URL=https://deine-domain.de

# Fahrzeuge (kommagetrennt)
VEHICLES=FLF1,FLF2,HLF,DLK,RTW

# === Uploads ===
MAX_UPLOAD_MB=8
MAX_UPLOAD_DIR_MB=500
COMPRESS_AFTER_DAYS=30

# === Datenbank ===
# DB_PATH=./data/stoerungen.db

# === Mail (SMTP) ===
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=user@example.com
MAIL_PASS=geheimes-passwort
MAIL_FROM="Störungsmelder LZ Frechen <noreply@example.com>"

# Alle Admins (Gruppe) – erhalten jeden Statuswechsel
# Wird als Fallback genutzt wenn ADMIN_ESCALATION nicht gesetzt ist.
MAIL_RECIPIENTS=admin1@example.com,admin2@example.com

# === Eskalationskette ===
# Geordnete Liste: username:email,username2:email2,...
# Der erste eintrag erhält neue Störungen sofort.
# Reagiert er nicht innerhalb von ESKALATION_STUNDEN Stunden,
# wird der nächste in der Kette benachrichtigt (sofern nicht abwesend).
# Username muss exakt dem Login-Namen entsprechen.
#
# Admins können sich über die Web-Oberfläche als abwesend markieren –
# sie werden dann in der Kette übersprungen.
ADMIN_ESCALATION=max:max@example.com,lisa:lisa@example.com,stefan:stefan@example.com

# Stunden bis zur Eskalation auf die nächste Stufe (Standard: 24)
ESKALATION_STUNDEN=24

# === Werkstatt-Ziele (für 'In Bearbeitung'-Benachrichtigung) ===
# Wird gesendet wenn Admin eine Störung auf 'In Bearbeitung' setzt.
# MAIL_KFZ   = Empfänger für Störungen der Klasse 'KFZ'
# MAIL_GERAET = Empfänger für Störungen der Klasse 'Gerät'
# Mehrere Adressen kommagetrennt möglich.
MAIL_KFZ=kfz-werkstatt@example.com
MAIL_GERAET=geraete-werkstatt@example.com

# === Admin-Einzel-Mails (optional, für persönliche Status-Bestätigungen) ===
# Format: username:email,username2:email2
# Wenn ADMIN_ESCALATION gesetzt ist, wird ADMIN_MAILS nur noch
# für persönliche Status-Bestätigungen genutzt (nicht mehr für Eskalation).
ADMIN_MAILS=max:max@example.com,lisa:lisa@example.com
