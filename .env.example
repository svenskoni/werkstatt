# ============================================================
#  Störungsmelder LZ Frechen – Umgebungsvariablen
#  Kopieren: cp .env.example .env
#  Dann alle Werte anpassen.
#
#  WICHTIG: Die App startet nicht, wenn eine Pflicht-Variable
#  fehlt oder leer ist. Optionale Variablen sind mit [optional]
#  markiert.
#
#  Hashes generieren:
#    node -e "const b=require('bcryptjs');b.hash('DEIN_PASSWORT',12).then(console.log)"
#  Oder online: https://bcrypt.online  (Cost Factor 12)
# ============================================================


# ------------------------------------------------------------
# App
# ------------------------------------------------------------

# Laufzeitumgebung: production | development
NODE_ENV=production

# Öffentliche Basis-URL (kein Slash am Ende)
APP_BASE_URL=https://werkstatt.lz-frechen.de

# Session-Geheimnis – langen zufälligen String verwenden
# Generieren: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=BITTE_AENDERN


# ------------------------------------------------------------
# Fahrzeuge
# Kommagetrennt, keine Leerzeichen
# ------------------------------------------------------------
VEHICLES=LF10,HLF20,TLF3000,DLA23,ELW1,MTF


# ------------------------------------------------------------
# Mannschaft-Login
# Ein gemeinsames Passwort für alle Mannschaftsmitglieder.
# Nur Passwort, kein Benutzername nötig.
# ------------------------------------------------------------
CREW_PASS_HASH=$2a$12$HASH_HIER_EINTRAGEN


# ------------------------------------------------------------
# Admin-Konten
# Beliebig viele Admins: ADMIN_1, ADMIN_2, ADMIN_3 …
# Jeder Admin hat einen eigenen Namen und Passwort-Hash.
# Admins können Status ändern und Störungen löschen.
# ------------------------------------------------------------
ADMIN_1_NAME=admin1
ADMIN_1_PASS_HASH=$2a$12$HASH_HIER_EINTRAGEN

ADMIN_2_NAME=admin2
ADMIN_2_PASS_HASH=$2a$12$HASH_HIER_EINTRAGEN

ADMIN_3_NAME=admin3
ADMIN_3_PASS_HASH=$2a$12$HASH_HIER_EINTRAGEN

# Weitere Admins einfach fortsetzen:
# ADMIN_4_NAME=admin4
# ADMIN_4_PASS_HASH=$2a$12$HASH_HIER_EINTRAGEN


# ------------------------------------------------------------
# Datenbank
# ------------------------------------------------------------

# [optional] Pfad zur SQLite-Datei
# Standard: <projektordner>/data/stoerungen.db
# DB_PATH=/var/data/stoerungen.db


# ------------------------------------------------------------
# Upload & Speicher
# ------------------------------------------------------------

# Max. Dateigröße pro Upload in MB
MAX_UPLOAD_MB=8

# Max. Gesamtgröße des Upload-Ordners in MB
MAX_UPLOAD_DIR_MB=5120

# Nach wie vielen Tagen werden Bilder erledigter Störungen komprimiert
COMPRESS_AFTER_DAYS=7


# ------------------------------------------------------------
# E-Mail (SMTP)
# ------------------------------------------------------------

# SMTP-Hostname
MAIL_HOST=smtp.your-server.de

# SMTP-Port
# 587 = STARTTLS (empfohlen)
# 465 = SSL/TLS
MAIL_PORT=587

# true  = direkte SSL/TLS-Verbindung (Port 465)
# false = STARTTLS (Port 587)
MAIL_SECURE=false

# SMTP-Login
MAIL_USER=stoerung@lz-frechen.de
MAIL_PASS=SMTP_PASSWORT_HIER

# Absender (Name + Adresse)
MAIL_FROM=Störungsmelder LZ Frechen <stoerung@lz-frechen.de>

# Empfänger der Benachrichtigungs-Mails (kommagetrennt)
MAIL_RECIPIENTS=werkstatt@lz-frechen.de,wehrfuehrer@lz-frechen.de
