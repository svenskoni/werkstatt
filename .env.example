# === App ===
NODE_ENV=production
SESSION_SECRET=bitte-sicheres-geheimnis-setzen
APP_BASE_URL=https://deine-domain.de

# Fahrzeuge (kommagetrennt)
VEHICLES=FLF1,FLF2,HLF,DLK,RTW

# === Uploads ===
MAX_UPLOAD_MB=8
MAX_UPLOAD_DIR_MB=500
COMPRESS_AFTER_DAYS=30

# === Datenbank ===
# DB_PATH=./data/stoerungen.db

# === Mail (SMTP) ===
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=user@example.com
MAIL_PASS=geheimes-passwort
MAIL_FROM="Störungsmelder LZ Frechen <noreply@example.com>"

# Alle Admins (Gruppe) – erhalten jede neue Störung und jeden Statuswechsel
MAIL_RECIPIENTS=admin1@example.com,admin2@example.com

# === Admin-Einzel-Mails (optional, für persönliche Benachrichtigungen & Erinnerungen) ===
# Format: username:email,username2:email2
# Der Username muss exakt dem Login-Namen entsprechen.
# Wird genutzt für:
#   - Persönliche Bestätigung wenn ein Admin einen Status ändert
#   - Erinnerungs-Mails (Reminder-Funktion)
# Wenn nicht gesetzt, werden Reminder an MAIL_RECIPIENTS gesendet.
ADMIN_MAILS=max:max@example.com,lisa:lisa@example.com
