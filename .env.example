# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
SESSION_SECRET=bitte-aendern-langer-zufaelliger-string
APP_BASE_URL=https://deine-domain.de
# PORT wird von Plesk/Phusion Passenger automatisch gesetzt – hier NICHT eintragen!

# ── Fahrzeuge ─────────────────────────────────────────────────────────────────
# Kommagetrennte Liste aller verfügbaren Fahrzeuge/Geräte
VEHICLES=LKW1,LKW2,MTW,ELW,HLF

# ── Uploads ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=8
MAX_UPLOAD_DIR_MB=500
COMPRESS_AFTER_DAYS=30

# ── Datenbank ─────────────────────────────────────────────────────────────────
# Optional: Pfad zur SQLite-Datei (Standard: data/stoerungen.db)
# DB_PATH=/opt/werkstatt/data/stoerungen.db

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=stoerungsmelder@example.com
MAIL_PASS=geheimes-passwort
MAIL_FROM="Störungsmelder LZ Frechen <stoerungsmelder@example.com>"

# ── Admin-Logins (PFLICHT) ────────────────────────────────────────────────────
# Admins loggen sich mit Benutzername + Passwort ein.
# Passwörter werden als bcrypt-Hash gespeichert (niemals Klartext!).
# Hash erzeugen: node -e "require('bcryptjs').hash('DeinPasswort',12).then(h=>console.log(h))"
#
# Beliebig viele Admins möglich, einfach nummeriert weiterführen:
ADMIN_1_NAME=max
ADMIN_1_PASS_HASH=$2b$12$ersetze-mich-mit-echtem-bcrypt-hash

ADMIN_2_NAME=lisa
ADMIN_2_PASS_HASH=$2b$12$ersetze-mich-mit-echtem-bcrypt-hash

# ── Melder-Login (PFLICHT) ──────────────────────────────────────────────────────
# Alle Melder teilen ein gemeinsames Passwort (kein Benutzername nötig).
# Ebenfalls als bcrypt-Hash speichern.
CREW_PASS_HASH=$2b$12$ersetze-mich-mit-echtem-bcrypt-hash

# ── Admin-Eskalation (PFLICHT) ────────────────────────────────────────────────
# Geordnete Eskalationsliste: username:email,username:email,...
# Erste Person = erste Benachrichtigung bei neuer Störung.
# Reagiert sie nicht innerhalb von ESKALATION_STUNDEN, geht die Mail
# an die nächste verfügbare Person (abwesende Admins werden übersprungen).
# Usernames müssen mit ADMIN_x_NAME übereinstimmen.
# Beispiel mit 3 Admins:
ADMIN_ESCALATION=max:max@feuerwehr-frechen.de,lisa:lisa@feuerwehr-frechen.de,tom:tom@feuerwehr-frechen.de

# ── Eskalations-Schwelle ─────────────────────────────────────────────────────
# Nach wie vielen Stunden ohne Reaktion wird eskaliert? (Standard: 24)
ESKALATION_STUNDEN=24

# ── Werkstatt-Empfänger (optional) ───────────────────────────────────────────
# Wird benachrichtigt wenn ein Ticket auf "In Bearbeitung" gesetzt wird.
# Mehrere Adressen kommagetrennt möglich.
MAIL_KFZ=kfz-werkstatt@example.com
MAIL_GERAET=geraete-werkstatt@example.com
