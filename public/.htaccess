# Plesk Passenger: Alle Anfragen an Node.js weiterleiten
Options -Indexes -MultiViews
DirectoryIndex disabled

# Statische Dateien direkt ausliefern (CSS, JS, Bilder, Uploads)
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Alles andere an Node.js (Passenger)
RewriteRule ^ ../app.js [L]

# Sicherheit: PHP-Ausführung verhindern
<FilesMatch "\.(?:php[0-9]?|phtml|phar)$">
    Require all denied
</FilesMatch>

# Sicherheits-Header
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
