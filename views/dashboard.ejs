<% const DASH_LIMIT = 10; %>
<div class="dashboard-container">
  <!-- Stats -->
  <div class="stats-bar" role="region" aria-label="Übersicht">
    <div class="stat-item">
      <span class="stat-num" style="color:var(--color-text)"><%= stats.total %></span>
      <span class="stat-label">Gesamt</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num" style="color:var(--color-new)"><%= stats.offen %></span>
      <span class="stat-label">Eingegangen</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num" style="color:var(--color-active)"><%= stats.aktiv %></span>
      <span class="stat-label">In Bearbeitung</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num" style="color:var(--color-done)"><%= stats.erledigt %></span>
      <span class="stat-label">Erledigt</span>
    </div>
    <% if (user) { %>
      <div class="stats-action">
        <a href="/stoerung/neu" class="btn btn-primary btn-sm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Neue Störung
        </a>
      </div>
    <% } %>
  </div>

  <!-- Filter-Leiste -->
  <div class="filter-bar" role="group" aria-label="Filter" style="display:flex;flex-wrap:wrap;align-items:center;gap:var(--space-2);padding:var(--space-3) var(--space-4);background:var(--color-surface);border-bottom:1px solid var(--color-divider);">
    <div class="filter-group" role="group" aria-label="Nach Fahrzeug filtern" style="display:flex;flex-wrap:wrap;gap:var(--space-2);">
      <button class="vf-btn" data-vf="" aria-pressed="false">Alle Fahrzeuge</button>
      <% VEHICLES.forEach(v => { %>
        <button class="vf-btn" data-vf="<%= v %>" aria-pressed="false"><%= v %></button>
      <% }); %>
    </div>
    <span style="width:1px;height:20px;background:var(--color-divider);flex-shrink:0;margin:0 var(--space-1)" aria-hidden="true"></span>
    <div class="filter-group" role="group" aria-label="Nach Klasse filtern" style="display:flex;gap:var(--space-2);">
      <button class="kf-btn kf-active" data-kf="" aria-pressed="true">Alle</button>
      <button class="kf-btn" data-kf="kfz" aria-pressed="false">KFZ</button>
      <button class="kf-btn" data-kf="geraet" aria-pressed="false">Gerät</button>
    </div>
    <span class="vf-count" style="margin-left:auto;font-size:var(--text-xs);color:var(--color-text-muted);align-self:center"></span>
  </div>

  <!-- Kanban -->
  <div class="kanban-board" role="main">

    <!-- Eingegangen -->
    <section class="kanban-col" aria-label="Eingegangene Störungen">
      <div class="kanban-header kanban-header-new">
        <div class="kanban-title-wrap">
          <span class="kanban-dot dot-new" aria-hidden="true"></span>
          <h2 class="kanban-title">Eingegangen</h2>
          <span class="kanban-count" id="cnt-gesendet"><%= gesendet.length %></span>
        </div>
        <p class="kanban-subtitle">Neu gemeldet, noch nicht bestätigt</p>
      </div>
      <div class="kanban-cards" id="col-gesendet">
        <% if (gesendet.length === 0) { %>
          <div class="empty-state-card">&#x2714; Keine offenen Meldungen</div>
        <% } %>
        <% gesendet.forEach(function(s, i) { %>
          <div class="kanban-card-wrap<% if (i >= DASH_LIMIT) { %> card-mehr-hidden<% } %>" data-fahrzeug="<%= s.fahrzeug %>" data-klasse="<%= s.klasse || 'kfz' %>">
            <%- include('partials/stoerung-card', { s, user }) %>
          </div>
        <% }); %>
      </div>
      <div class="kanban-empty-filter" id="empty-gesendet" hidden style="padding:var(--space-6) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">Keine Einträge für diesen Filter</div>
      <% if (gesendet.length > DASH_LIMIT) { %>
        <div id="mehr-gesendet" style="padding:var(--space-2) var(--space-4) var(--space-4);text-align:center">
          <button class="btn btn-ghost btn-sm mehr-btn" data-col="col-gesendet" data-mehr="mehr-gesendet">
            &#9660; <%= gesendet.length - DASH_LIMIT %> weitere anzeigen
          </button>
        </div>
      <% } %>
    </section>

    <!-- In Bearbeitung -->
    <section class="kanban-col" aria-label="Störungen in Bearbeitung">
      <div class="kanban-header kanban-header-active">
        <div class="kanban-title-wrap">
          <span class="kanban-dot dot-active" aria-hidden="true"></span>
          <h2 class="kanban-title">In Bearbeitung</h2>
          <span class="kanban-count" id="cnt-bestaetigt"><%= bestaetigt.length %></span>
        </div>
        <p class="kanban-subtitle">Bestätigt, wird bearbeitet</p>
      </div>
      <div class="kanban-cards" id="col-bestaetigt">
        <% if (bestaetigt.length === 0) { %>
          <div class="empty-state-card">&mdash; Nichts in Bearbeitung</div>
        <% } %>
        <% bestaetigt.forEach(function(s, i) { %>
          <div class="kanban-card-wrap<% if (i >= DASH_LIMIT) { %> card-mehr-hidden<% } %>" data-fahrzeug="<%= s.fahrzeug %>" data-klasse="<%= s.klasse || 'kfz' %>">
            <%- include('partials/stoerung-card', { s, user }) %>
          </div>
        <% }); %>
      </div>
      <div class="kanban-empty-filter" id="empty-bestaetigt" hidden style="padding:var(--space-6) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">Keine Einträge für diesen Filter</div>
      <% if (bestaetigt.length > DASH_LIMIT) { %>
        <div id="mehr-bestaetigt" style="padding:var(--space-2) var(--space-4) var(--space-4);text-align:center">
          <button class="btn btn-ghost btn-sm mehr-btn" data-col="col-bestaetigt" data-mehr="mehr-bestaetigt">
            &#9660; <%= bestaetigt.length - DASH_LIMIT %> weitere anzeigen
          </button>
        </div>
      <% } %>
    </section>

    <!-- Erledigt (lazy per API, nur 10 aus DB) -->
    <section class="kanban-col" aria-label="Erledigte und zurückgewiesene Störungen">
      <div class="kanban-header kanban-header-done">
        <div class="kanban-title-wrap">
          <span class="kanban-dot dot-done" aria-hidden="true"></span>
          <h2 class="kanban-title">Erledigt</h2>
          <span class="kanban-count" id="cnt-erledigt"><%= stats.erledigt %></span>
        </div>
        <p class="kanban-subtitle">Abgeschlossen &amp; Zurückgewiesen &middot; letzte 10</p>
      </div>
      <div class="kanban-cards" id="col-erledigt">
        <div class="erledigt-loading" style="padding:var(--space-6) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">Wird geladen…</div>
      </div>
      <div class="kanban-empty-filter" id="empty-erledigt" hidden style="padding:var(--space-6) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">Keine Einträge für diesen Filter</div>
      <div id="erledigt-suche-hint" hidden style="padding:var(--space-2) var(--space-4) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">
        Zeige letzte 10 von <%= stats.erledigt %> &middot;
        <button type="button" id="erledigt-suche-btn" style="background:none;border:none;padding:0;color:var(--color-primary);cursor:pointer;font-size:inherit;text-decoration:underline">Alle in der Suche</button>
      </div>
    </section>

  </div>
</div>

<script>
(function () {
  const PAGE_SIZE = 10;
  const vfBtns = document.querySelectorAll('.vf-btn');
  const kfBtns = document.querySelectorAll('.kf-btn');
  const localCols = [
    { cards: 'col-gesendet',   cnt: 'cnt-gesendet',   empty: 'empty-gesendet',   mehr: 'mehr-gesendet'   },
    { cards: 'col-bestaetigt', cnt: 'cnt-bestaetigt', empty: 'empty-bestaetigt', mehr: 'mehr-bestaetigt' },
  ];
  const countEl = document.querySelector('.vf-count');
  let activeVf = '';
  let activeKf = '';

  // ── Mehr-anzeigen-Buttons ─────────────────────────────────────────────────
  document.querySelectorAll('.mehr-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var colEl  = document.getElementById(btn.dataset.col);
      var mehrEl = document.getElementById(btn.dataset.mehr);
      colEl.querySelectorAll('.card-mehr-hidden').forEach(function (w) {
        w.classList.remove('card-mehr-hidden');
        w.style.display = '';
      });
      mehrEl.style.display = 'none';
      // Filter neu anwenden, damit frisch eingeblendete Karten korrekt gefiltert werden
      applyLocalFilter();
    });
  });

  // ── Erledigt: API-Aufruf ─────────────────────────────────────────────────
  const erledigtCol   = document.getElementById('col-erledigt');
  const erledigtEmpty = document.getElementById('empty-erledigt');
  const erledigtHint  = document.getElementById('erledigt-suche-hint');
  let erledigtTimer   = null;

  var suchBtn = document.getElementById('erledigt-suche-btn');
  if (suchBtn) {
    suchBtn.addEventListener('click', function () {
      var searchBtn = document.getElementById('searchBtn');
      if (searchBtn) searchBtn.click();
    });
  }

  function loadErledigt() {
    var params = new URLSearchParams();
    if (activeVf) params.set('fahrzeug', activeVf);
    if (activeKf) params.set('klasse',   activeKf);
    erledigtCol.innerHTML = '<div style="padding:var(--space-6) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">Wird geladen\u2026</div>';
    erledigtEmpty.hidden = true;
    erledigtHint.hidden  = true;
    fetch('/api/dashboard/erledigt?' + params.toString())
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.error) { erledigtCol.innerHTML = '<div style="padding:var(--space-4);color:var(--color-error);font-size:var(--text-xs)">Fehler beim Laden.</div>'; return; }
        if (!data.html || data.total === 0) {
          erledigtCol.innerHTML = '';
          erledigtEmpty.hidden  = false;
        } else {
          erledigtCol.innerHTML = data.html;
          erledigtHint.hidden   = (data.total < PAGE_SIZE);
        }
      })
      .catch(function () {
        erledigtCol.innerHTML = '<div style="padding:var(--space-4);color:var(--color-error);font-size:var(--text-xs)">Netzwerkfehler.</div>';
      });
  }

  // ── Lokaler Filter ─────────────────────────────────────────────────────────────────
  function applyLocalFilter() {
    var totalVisible = 0;
    localCols.forEach(function (col) {
      var colEl   = document.getElementById(col.cards);
      var cntEl   = document.getElementById(col.cnt);
      var emptyEl = document.getElementById(col.empty);
      var mehrEl  = col.mehr ? document.getElementById(col.mehr) : null;
      var wraps   = Array.from(colEl.querySelectorAll('.kanban-card-wrap'));

      var matching = wraps.filter(function (w) {
        var matchVf = !activeVf || w.dataset.fahrzeug === activeVf;
        var matchKf = !activeKf || w.dataset.klasse   === activeKf;
        return matchVf && matchKf;
      });

      wraps.forEach(function (w) {
        var matchVf = !activeVf || w.dataset.fahrzeug === activeVf;
        var matchKf = !activeKf || w.dataset.klasse   === activeKf;
        var filterOk     = matchVf && matchKf;
        var isMehrHidden = w.classList.contains('card-mehr-hidden');
        w.style.display  = (filterOk && !isMehrHidden) ? '' : 'none';
      });

      cntEl.textContent = matching.length;
      totalVisible += matching.length;
      emptyEl.hidden = !(wraps.length > 0 && matching.length === 0);

      // ── Fix #49: Mehr-Button an gefilterte Anzahl anpassen ──────────────
      if (mehrEl) {
        // Wie viele passende Karten sind noch versteckt (card-mehr-hidden)?
        var hiddenMatching = matching.filter(function (w) {
          return w.classList.contains('card-mehr-hidden');
        });
        if (hiddenMatching.length > 0) {
          // Button sichtbar lassen und Zahl aktualisieren
          mehrEl.style.display = '';
          var btn = mehrEl.querySelector('.mehr-btn');
          if (btn) btn.textContent = '\u25BC ' + hiddenMatching.length + ' weitere anzeigen';
        } else {
          // Keine passenden versteckten Karten mehr → Button ausblenden
          mehrEl.style.display = 'none';
        }
      }
    });

    var parts = [];
    if (activeVf) parts.push('\u00bb' + activeVf + '\u00ab');
    if (activeKf) parts.push(activeKf === 'kfz' ? 'KFZ' : 'Ger\u00e4t');
    countEl.textContent = parts.length ? totalVisible + ' sichtbar \u00b7 ' + parts.join(' + ') : '';
  }

  function applyFilter() {
    applyLocalFilter();
    clearTimeout(erledigtTimer);
    erledigtTimer = setTimeout(loadErledigt, 120);
  }

  function setVf(val) {
    activeVf = val;
    vfBtns.forEach(function (b) { var m = b.dataset.vf === val; b.classList.toggle('vf-active', m); b.setAttribute('aria-pressed', m ? 'true' : 'false'); });
    try { sessionStorage.setItem('vf_active', val); } catch {}
    applyFilter();
  }
  function setKf(val) {
    activeKf = val;
    kfBtns.forEach(function (b) { var m = b.dataset.kf === val; b.classList.toggle('kf-active', m); b.setAttribute('aria-pressed', m ? 'true' : 'false'); });
    try { sessionStorage.setItem('kf_active', val); } catch {}
    applyFilter();
  }

  var savedVf = '', savedKf = '';
  try { savedVf = sessionStorage.getItem('vf_active') || ''; } catch {}
  try { savedKf = sessionStorage.getItem('kf_active') || ''; } catch {}
  var validVf = Array.from(vfBtns).map(function (b) { return b.dataset.vf; });
  var validKf = Array.from(kfBtns).map(function (b) { return b.dataset.kf; });
  if (!validVf.includes(savedVf)) savedVf = '';
  if (!validKf.includes(savedKf)) savedKf = '';
  activeVf = savedVf; activeKf = savedKf;
  vfBtns.forEach(function (b) { var m = b.dataset.vf === savedVf; b.classList.toggle('vf-active', m); b.setAttribute('aria-pressed', m ? 'true' : 'false'); });
  kfBtns.forEach(function (b) { var m = b.dataset.kf === savedKf; b.classList.toggle('kf-active', m); b.setAttribute('aria-pressed', m ? 'true' : 'false'); });
  vfBtns.forEach(function (btn) { btn.addEventListener('click', function () { setVf(btn.dataset.vf); }); });
  kfBtns.forEach(function (btn) { btn.addEventListener('click', function () { setKf(btn.dataset.kf); }); });
  applyLocalFilter();
  loadErledigt();
})();
</script>
