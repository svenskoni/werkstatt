<div class="dashboard-container">
  <!-- Stats -->
  <div class="stats-bar" role="region" aria-label="Übersicht">
    <div class="stat-item">
      <span class="stat-num" style="color:var(--color-text)"><%= stats.total %></span>
      <span class="stat-label">Gesamt</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num" style="color:var(--color-new)"><%= stats.offen %></span>
      <span class="stat-label">Eingegangen</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num" style="color:var(--color-active)"><%= stats.aktiv %></span>
      <span class="stat-label">In Bearbeitung</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num" style="color:var(--color-done)"><%= stats.erledigt %></span>
      <span class="stat-label">Erledigt</span>
    </div>
    <% if (user) { %>
      <div class="stats-action">
        <a href="/stoerung/neu" class="btn btn-primary btn-sm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Neue Störung
        </a>
      </div>
    <% } %>
  </div>

  <!-- Filter-Leiste -->
  <div class="filter-bar" role="group" aria-label="Filter" style="
    display:flex;flex-wrap:wrap;align-items:center;gap:var(--space-2);padding:var(--space-3) var(--space-4);
    background:var(--color-surface);border-bottom:1px solid var(--color-divider);">

    <div class="filter-group" role="group" aria-label="Nach Fahrzeug filtern" style="display:flex;flex-wrap:wrap;gap:var(--space-2);">
      <button class="vf-btn" data-vf="" aria-pressed="false">Alle Fahrzeuge</button>
      <% VEHICLES.forEach(v => { %>
        <button class="vf-btn" data-vf="<%= v %>" aria-pressed="false"><%= v %></button>
      <% }); %>
    </div>

    <span style="width:1px;height:20px;background:var(--color-divider);flex-shrink:0;margin:0 var(--space-1)" aria-hidden="true"></span>

    <div class="filter-group" role="group" aria-label="Nach Klasse filtern" style="display:flex;gap:var(--space-2);">
      <button class="kf-btn kf-active" data-kf="" aria-pressed="true">Alle</button>
      <button class="kf-btn" data-kf="kfz" aria-pressed="false">KFZ</button>
      <button class="kf-btn" data-kf="geraet" aria-pressed="false">Ger&auml;t</button>
    </div>

    <span class="vf-count" style="margin-left:auto;font-size:var(--text-xs);color:var(--color-text-muted);align-self:center"></span>
  </div>

  <!-- Kanban -->
  <div class="kanban-board" role="main">

    <section class="kanban-col" aria-label="Eingegangene Störungen">
      <div class="kanban-header kanban-header-new">
        <div class="kanban-title-wrap">
          <span class="kanban-dot dot-new" aria-hidden="true"></span>
          <h2 class="kanban-title">Eingegangen</h2>
          <span class="kanban-count" id="cnt-gesendet"><%= gesendet.length %></span>
        </div>
        <p class="kanban-subtitle">Neu gemeldet, noch nicht bestätigt</p>
      </div>
      <div class="kanban-cards" id="col-gesendet">
        <% if (gesendet.length === 0) { %>
          <div class="empty-state-card">&#x2714; Keine offenen Meldungen</div>
        <% } %>
        <% gesendet.forEach(s => { %>
          <div class="kanban-card-wrap" data-fahrzeug="<%= s.fahrzeug %>" data-klasse="<%= s.klasse || 'kfz' %>">
            <%- include('partials/stoerung-card', { s, user }) %>
          </div>
        <% }); %>
      </div>
      <div class="kanban-empty-filter" id="empty-gesendet" hidden style="padding:var(--space-6) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">Keine Einträge für diesen Filter</div>
      <div class="col-load-more" id="more-gesendet" hidden>
        <button class="load-more-btn" data-col="gesendet">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          <span class="load-more-label"></span>
        </button>
      </div>
    </section>

    <section class="kanban-col" aria-label="Störungen in Bearbeitung">
      <div class="kanban-header kanban-header-active">
        <div class="kanban-title-wrap">
          <span class="kanban-dot dot-active" aria-hidden="true"></span>
          <h2 class="kanban-title">In Bearbeitung</h2>
          <span class="kanban-count" id="cnt-bestaetigt"><%= bestaetigt.length %></span>
        </div>
        <p class="kanban-subtitle">Bestätigt, wird bearbeitet</p>
      </div>
      <div class="kanban-cards" id="col-bestaetigt">
        <% if (bestaetigt.length === 0) { %>
          <div class="empty-state-card">&mdash; Nichts in Bearbeitung</div>
        <% } %>
        <% bestaetigt.forEach(s => { %>
          <div class="kanban-card-wrap" data-fahrzeug="<%= s.fahrzeug %>" data-klasse="<%= s.klasse || 'kfz' %>">
            <%- include('partials/stoerung-card', { s, user }) %>
          </div>
        <% }); %>
      </div>
      <div class="kanban-empty-filter" id="empty-bestaetigt" hidden style="padding:var(--space-6) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">Keine Einträge für diesen Filter</div>
      <div class="col-load-more" id="more-bestaetigt" hidden>
        <button class="load-more-btn" data-col="bestaetigt">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          <span class="load-more-label"></span>
        </button>
      </div>
    </section>

    <section class="kanban-col" aria-label="Erledigte und zurückgewiesene Störungen">
      <div class="kanban-header kanban-header-done">
        <div class="kanban-title-wrap">
          <span class="kanban-dot dot-done" aria-hidden="true"></span>
          <h2 class="kanban-title">Erledigt</h2>
          <span class="kanban-count" id="cnt-erledigt"><%= erledigt.length + zurueckgewiesen.length %></span>
        </div>
        <p class="kanban-subtitle">Abgeschlossen &amp; Zurückgewiesen</p>
      </div>
      <div class="kanban-cards" id="col-erledigt">
        <% if (erledigt.length === 0 && zurueckgewiesen.length === 0) { %>
          <div class="empty-state-card">&mdash; Noch nichts erledigt</div>
        <% } %>
        <% erledigt.forEach(s => { %>
          <div class="kanban-card-wrap" data-fahrzeug="<%= s.fahrzeug %>" data-klasse="<%= s.klasse || 'kfz' %>">
            <%- include('partials/stoerung-card', { s, user }) %>
          </div>
        <% }); %>
        <% zurueckgewiesen.forEach(s => { %>
          <div class="kanban-card-wrap" data-fahrzeug="<%= s.fahrzeug %>" data-klasse="<%= s.klasse || 'kfz' %>">
            <div style="margin-bottom:var(--space-1)">
              <span style="display:inline-block;font-size:var(--text-xs);font-weight:600;padding:2px 8px;border-radius:var(--radius-full);background:var(--color-primary-highlight);color:var(--color-primary);letter-spacing:0.02em">✕ Ticket zurückgewiesen</span>
            </div>
            <%- include('partials/stoerung-card', { s, user }) %>
          </div>
        <% }); %>
      </div>
      <div class="kanban-empty-filter" id="empty-erledigt" hidden style="padding:var(--space-6) var(--space-4);text-align:center;font-size:var(--text-xs);color:var(--color-text-faint)">Keine Einträge für diesen Filter</div>
      <div class="col-load-more" id="more-erledigt" hidden>
        <button class="load-more-btn" data-col="erledigt">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          <span class="load-more-label"></span>
        </button>
      </div>
    </section>

  </div>
</div>

<style>
.vf-btn, .kf-btn {
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-weight: 500;
  cursor: pointer;
  transition: background var(--transition-interactive), color var(--transition-interactive), border-color var(--transition-interactive);
}
.vf-btn:hover, .kf-btn:hover { background: var(--color-surface-offset); color: var(--color-text); }
.vf-btn.vf-active {
  background: var(--color-primary); border-color: var(--color-primary);
  color: #fff; font-weight: 600;
}
.kf-btn.kf-active {
  background: var(--color-primary); border-color: var(--color-primary);
  color: #fff; font-weight: 600;
}

/* Load-more Button */
.col-load-more {
  padding: var(--space-2) var(--space-4) var(--space-4);
}
.load-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  width: 100%;
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-md);
  border: 1px dashed var(--color-border);
  background: var(--color-surface);
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-weight: 500;
  cursor: pointer;
  transition: background var(--transition-interactive), color var(--transition-interactive), border-color var(--transition-interactive);
}
.load-more-btn:hover {
  background: var(--color-surface-offset);
  color: var(--color-text);
  border-color: var(--color-primary);
}
.load-more-btn svg {
  flex-shrink: 0;
  transition: transform 200ms ease;
}
</style>

<script>
(function () {
  const PAGE_SIZE = 10;

  const vfBtns = document.querySelectorAll('.vf-btn');
  const kfBtns = document.querySelectorAll('.kf-btn');
  const cols  = [
    { cards: 'col-gesendet',   cnt: 'cnt-gesendet',   empty: 'empty-gesendet',   more: 'more-gesendet'   },
    { cards: 'col-bestaetigt', cnt: 'cnt-bestaetigt', empty: 'empty-bestaetigt', more: 'more-bestaetigt' },
    { cards: 'col-erledigt',   cnt: 'cnt-erledigt',   empty: 'empty-erledigt',   more: 'more-erledigt'   },
  ];
  const countEl = document.querySelector('.vf-count');

  let activeVf = '';
  let activeKf = '';

  // visibleCount pro Spalte – wie viele Karten aktuell aufgeklappt sind
  const visibleCount = { gesendet: PAGE_SIZE, bestaetigt: PAGE_SIZE, erledigt: PAGE_SIZE };

  function applyFilter() {
    let totalVisible = 0;

    cols.forEach(({ cards, cnt, empty, more }) => {
      const col     = document.getElementById(cards);
      const cntEl   = document.getElementById(cnt);
      const emptyEl = document.getElementById(empty);
      const moreEl  = document.getElementById(more);
      const wraps   = Array.from(col.querySelectorAll('.kanban-card-wrap'));

      // Filtere zuerst – welche Karten matchen überhaupt?
      const matching = wraps.filter(w => {
        const matchVf = !activeVf || w.dataset.fahrzeug === activeVf;
        const matchKf = !activeKf || w.dataset.klasse   === activeKf;
        return matchVf && matchKf;
      });

      // Welche sind hidden wegen Paging?
      const colKey = cards.replace('col-', '');
      const limit  = visibleCount[colKey] || PAGE_SIZE;

      let shown = 0;
      wraps.forEach(w => {
        const matchVf = !activeVf || w.dataset.fahrzeug === activeVf;
        const matchKf = !activeKf || w.dataset.klasse   === activeKf;
        const matches = matchVf && matchKf;
        // Innerhalb der matching-Liste: nur bis limit anzeigen
        const rankInMatching = matches ? matching.indexOf(w) : -1;
        const withinLimit    = rankInMatching >= 0 && rankInMatching < limit;
        w.style.display = withinLimit ? '' : 'none';
        if (withinLimit) shown++;
      });

      cntEl.textContent = matching.length;
      totalVisible += shown;

      emptyEl.hidden = !(wraps.length > 0 && matching.length === 0);

      // More-Button
      const remaining = matching.length - limit;
      if (remaining > 0) {
        const btn = moreEl.querySelector('.load-more-btn');
        const label = btn.querySelector('.load-more-label');
        label.textContent = remaining <= PAGE_SIZE
          ? `${remaining} weitere anzeigen`
          : `${PAGE_SIZE} weitere laden (noch ${remaining})`;
        moreEl.hidden = false;
      } else {
        moreEl.hidden = true;
      }
    });

    const parts = [];
    if (activeVf) parts.push(`»${activeVf}«`);
    if (activeKf) parts.push(activeKf === 'kfz' ? 'KFZ' : 'Gerät');
    countEl.textContent = parts.length ? `${totalVisible} sichtbar · ${parts.join(' + ')}` : '';
  }

  // Load-more Buttons
  document.querySelectorAll('.load-more-btn').forEach(btn => {
    btn.addEventListener('click', function () {
      const col = this.dataset.col;
      visibleCount[col] = (visibleCount[col] || PAGE_SIZE) + PAGE_SIZE;
      applyFilter();
      // Scroll zur ersten neu sichtbaren Karte
      const colEl = document.getElementById('col-' + col);
      const newCards = colEl.querySelectorAll('.kanban-card-wrap:not([style*="none"])');
      const target   = newCards[newCards.length - PAGE_SIZE];
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });

  function setVf(val) {
    activeVf = val;
    // Filter-Wechsel: Paging zurücksetzen
    Object.keys(visibleCount).forEach(k => visibleCount[k] = PAGE_SIZE);
    vfBtns.forEach(b => {
      const match = b.dataset.vf === val;
      b.classList.toggle('vf-active', match);
      b.setAttribute('aria-pressed', match ? 'true' : 'false');
    });
    try { sessionStorage.setItem('vf_active', val); } catch {}
    applyFilter();
  }

  function setKf(val) {
    activeKf = val;
    Object.keys(visibleCount).forEach(k => visibleCount[k] = PAGE_SIZE);
    kfBtns.forEach(b => {
      const match = b.dataset.kf === val;
      b.classList.toggle('kf-active', match);
      b.setAttribute('aria-pressed', match ? 'true' : 'false');
    });
    try { sessionStorage.setItem('kf_active', val); } catch {}
    applyFilter();
  }

  let savedVf = '', savedKf = '';
  try { savedVf = sessionStorage.getItem('vf_active') || ''; } catch {}
  try { savedKf = sessionStorage.getItem('kf_active') || ''; } catch {}
  const validVf = Array.from(vfBtns).map(b => b.dataset.vf);
  const validKf = Array.from(kfBtns).map(b => b.dataset.kf);
  if (!validVf.includes(savedVf)) savedVf = '';
  if (!validKf.includes(savedKf)) savedKf = '';

  activeVf = savedVf;
  activeKf = savedKf;
  vfBtns.forEach(b => { const m = b.dataset.vf === savedVf; b.classList.toggle('vf-active', m); b.setAttribute('aria-pressed', m ? 'true' : 'false'); });
  kfBtns.forEach(b => { const m = b.dataset.kf === savedKf; b.classList.toggle('kf-active', m); b.setAttribute('aria-pressed', m ? 'true' : 'false'); });
  applyFilter();

  vfBtns.forEach(btn => btn.addEventListener('click', () => setVf(btn.dataset.vf)));
  kfBtns.forEach(btn => btn.addEventListener('click', () => setKf(btn.dataset.kf)));
})();
</script>
