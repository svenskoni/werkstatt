<!DOCTYPE html>
<html lang="de" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="refresh" content="60">
  <title>Störungsübersicht</title>
  <style>
    /* ── Reset & Basis ───────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      overflow: hidden;
      background: #0f0f0f;
      color: #e0e0e0;
      font-family: 'Segoe UI', Arial, sans-serif;
      font-size: 13px;
    }

    /* ── Layout ─────────────────────────────────────── */
    .page {
      display: flex;
      flex-direction: column;
      height: 100vh;
    }

    /* ── Header ─────────────────────────────────────── */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 6px 12px;
      background: #181818;
      border-bottom: 1px solid #2a2a2a;
      flex-shrink: 0;
      gap: 16px;
    }
    .header-title {
      font-size: 15px;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }
    .header-badges {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }
    .badge-offen  { background: #3b2a00; color: #f5a623; border: 1px solid #6b4e00; }
    .badge-aktiv  { background: #002a3b; color: #4cb8d8; border: 1px solid #005a7a; }
    .header-clock {
      font-size: 13px;
      color: #888;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    /* ── Fahrzeug-Grid ──────────────────────────────── */
    .grid {
      display: flex;
      flex: 1;
      overflow: hidden;
      gap: 1px;
      background: #1a1a1a;
    }
    .col {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-width: 0;
      background: #111;
      overflow: hidden;
    }
    .col-header {
      padding: 5px 6px 4px;
      background: #1c1c1c;
      border-bottom: 2px solid #2e2e2e;
      flex-shrink: 0;
    }
    .col-header-name {
      font-size: 12px;
      font-weight: 700;
      color: #ccc;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .col-body {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      scrollbar-width: none;
      padding: 3px;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .col-body::-webkit-scrollbar { display: none; }

    /* ── Abschnitt-Label (Offen / In Bearbeitung) ─────── */
    .section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 2px 3px 1px;
      margin-top: 2px;
      border-radius: 2px;
    }
    .section-label.offen  { color: #f5a623; background: rgba(245,166,35,0.08); }
    .section-label.aktiv  { color: #4cb8d8; background: rgba(76,184,216,0.08); }

    /* ── Ticket-Karte ──────────────────────────────── */
    .ticket {
      border-radius: 3px;
      padding: 4px 5px;
      font-size: 11px;
      line-height: 1.35;
      border-left: 3px solid transparent;
      background: #1a1a1a;
      overflow: hidden;
    }
    .ticket.offen {
      border-left-color: #f5a623;
      background: #1e1800;
    }
    .ticket.aktiv {
      border-left-color: #4cb8d8;
      background: #001822;
    }
    .ticket-fehler {
      color: #e0e0e0;
      word-break: break-word;
      overflow-wrap: break-word;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .ticket-meta {
      display: flex;
      align-items: center;
      gap: 4px;
      margin-top: 2px;
      flex-wrap: wrap;
    }
    .ticket-schwere {
      font-size: 9px;
      opacity: 0.7;
      white-space: nowrap;
    }
    .ticket-klasse {
      font-size: 10px;
      opacity: 0.75;
      white-space: nowrap;
    }
    .ticket-zeit {
      font-size: 9px;
      color: #666;
      white-space: nowrap;
      margin-left: auto;
    }

    /* ── Leer-Zustand ──────────────────────────────── */
    .empty {
      color: #333;
      font-size: 10px;
      text-align: center;
      padding: 8px 2px;
      font-style: italic;
    }

    /* ── Spalte ohne Tickets: abgedunkelt ──────────── */
    .col.leer .col-header { opacity: 0.35; }
    .col.leer { background: #0d0d0d; }
  </style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="header">
    <span class="header-title">🚨 Störungsübersicht</span>
    <div class="header-badges">
      <span class="badge badge-offen">⚠️ Offen: <%= anzahlOffen %></span>
      <span class="badge badge-aktiv">🔧 In Bearbeitung: <%= anzahlAktiv %></span>
    </div>
    <span class="header-clock" id="clock"></span>
  </div>

  <!-- Fahrzeug-Spalten -->
  <div class="grid">
    <% fahrzeugDaten.forEach(function(fz) { %>
      <% var hatTickets = fz.offen.length > 0 || fz.aktiv.length > 0; %>
      <div class="col<%= hatTickets ? '' : ' leer' %>">
        <div class="col-header">
          <div class="col-header-name"><%= fz.name %></div>
        </div>
        <div class="col-body">

          <% if (fz.offen.length > 0) { %>
            <div class="section-label offen">⚠️ Offen</div>
            <% fz.offen.forEach(function(t) { %>
              <div class="ticket offen">
                <div class="ticket-fehler"><%= t.fehlerBeschreibung %></div>
                <div class="ticket-meta">
                  <% var sw = SCHWERE[t.schwere]; %>
                  <% if (sw) { %><span class="ticket-schwere"><%= sw.icon %> <%= sw.label %></span><% } %>
                  <span class="ticket-klasse"><%= t.klasse === 'geraet' ? '🔧' : '🚒' %></span>
                  <span class="ticket-zeit"><%= new Date(t.createdAt).toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',timeZone:'Europe/Berlin'}) %></span>
                </div>
              </div>
            <% }); %>
          <% } %>

          <% if (fz.aktiv.length > 0) { %>
            <div class="section-label aktiv">🔧 Bearbeitung</div>
            <% fz.aktiv.forEach(function(t) { %>
              <div class="ticket aktiv">
                <div class="ticket-fehler"><%= t.fehlerBeschreibung %></div>
                <div class="ticket-meta">
                  <% var sw2 = SCHWERE[t.schwere]; %>
                  <% if (sw2) { %><span class="ticket-schwere"><%= sw2.icon %> <%= sw2.label %></span><% } %>
                  <span class="ticket-klasse"><%= t.klasse === 'geraet' ? '🔧' : '🚒' %></span>
                  <span class="ticket-zeit"><%= new Date(t.createdAt).toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',timeZone:'Europe/Berlin'}) %></span>
                </div>
              </div>
            <% }); %>
          <% } %>

          <% if (fz.offen.length === 0 && fz.aktiv.length === 0) { %>
            <div class="empty">—</div>
          <% } %>

        </div>
      </div>
    <% }); %>
  </div>

</div>

<script>
  // Live-Uhr
  (function tick() {
    var now = new Date();
    var pad = function(n) { return String(n).padStart(2,'0'); };
    document.getElementById('clock').textContent =
      pad(now.getHours()) + ':' + pad(now.getMinutes()) + ':' + pad(now.getSeconds());
    setTimeout(tick, 1000);
  })();
</script>
</body>
</html>
