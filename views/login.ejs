<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <svg width="56" height="56" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect width="32" height="32" rx="6" fill="#c0392b"/>
        <path d="M8 22 L16 8 L24 22 Z" fill="white" opacity="0.95"/>
        <rect x="13" y="17" width="6" height="5" rx="1" fill="#c0392b"/>
      </svg>
      <h1 class="auth-title">Störungsmelder</h1>
    </div>

    <% if (error) { %>
      <div class="alert alert-error" role="alert"><%= error %></div>
    <% } %>

    <form action="/login" method="POST" autocomplete="on" novalidate>
      <div class="form-group">
        <label class="form-label required" for="username">Benutzername</label>
        <input
          type="text"
          id="username"
          name="username"
          class="form-control"
          autocomplete="username"
          required
          autofocus
          maxlength="80"
          spellcheck="false"
        >
      </div>

      <div class="form-group">
        <label class="form-label required" for="password">Passwort</label>
        <div class="password-wrap">
          <input
            type="password"
            id="password"
            name="password"
            class="form-control"
            autocomplete="current-password"
            required
            maxlength="200"
          >
          <button type="button" class="pw-toggle" onclick="togglePw()" aria-label="Passwort anzeigen">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top:var(--space-2)">
        Anmelden
      </button>
    </form>
    <p class="auth-note">Nur für autorisierte Mitglieder der Feuerwehr LZ Frechen.</p>
  </div>
</div>
<script>
function togglePw() {
  const i = document.getElementById('password');
  i.type = i.type === 'password' ? 'text' : 'password';
}
</script>
