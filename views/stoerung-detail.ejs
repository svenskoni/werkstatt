<%
function formatDate(iso) {
  return new Date(iso).toLocaleString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',timeZone:'Europe/Berlin'});
}
const benachrichtigt = Number(storung.melderBenachrichtigung) === 1;
const STATUS_LABEL = {
  gesendet:        'Eingegangen',
  bestaetigt:      'In Bearbeitung',
  erledigt:        'Erledigt',
  zurueckgewiesen: 'Zurückgewiesen',
};
// Issue #4: Klasse-Label
const KLASSE_LABEL = { kfz: 'KFZ', geraet: 'Gerät' };
const hasReminder  = !!storung.reminderAt;
const reminderDate = hasReminder ? new Date(storung.reminderAt).toLocaleString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',timeZone:'Europe/Berlin'}) : null;
function toLocalInput(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  const pad = n => String(n).padStart(2,'0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}
%>
<div class="form-container">
  <div class="form-header">
    <a href="/" class="back-link">&larr; Dashboard</a>
    <h1 class="page-title">Störung: <%= storung.fahrzeug %></h1>
  </div>

  <div class="detail-grid">
    <div class="detail-card">
      <table class="detail-table">
        <tr><th>Fahrzeug</th><td><strong><%= storung.fahrzeug %></strong></td></tr>
        <tr><th>Klasse</th><td>
          <span style="display:inline-block;padding:2px 10px;border-radius:12px;font-size:var(--text-xs);font-weight:700;background:var(--color-primary-highlight);color:var(--color-primary)">
            <%= storung.klasse === 'geraet' ? '🔧 Gerät' : '🚒 KFZ' %>
          </span>
        </td></tr>
        <tr><th>Schweregrad</th><td>
          <% const sw = SCHWERE[storung.schwere]; %>
          <% if (sw) { %>
            <span class="schwere-badge schwere-<%= storung.schwere.toLowerCase() %>"><%= sw.icon %> <%= sw.label %></span>
          <% } else { %>
            <span class="schwere-badge"><%= storung.schwere %></span>
          <% } %>
        </td></tr>
        <tr><th>Fehler</th><td><%= storung.fehlerBeschreibung %></td></tr>
        <tr><th>Status</th><td><strong><%= STATUS_LABEL[storung.status] || storung.status %></strong></td></tr>
        <tr><th>Gemeldet von</th><td><%= storung.melderName %> &ndash; <%= storung.melderKontakt %></td></tr>
        <tr><th>Erfasst von</th><td><%= storung.createdBy %></td></tr>
        <tr><th>Zeitpunkt</th><td><%= formatDate(storung.createdAt) %></td></tr>
        <tr><th>Meldungs-ID</th><td><code style="font-size:var(--text-xs)"><%= storung.id %></code></td></tr>
        <tr><th>Statusupdates</th><td>
          <% if (benachrichtigt) { %>
            <span style="color:var(--color-success);font-size:var(--text-sm)">&#10003; Melder wird benachrichtigt</span>
          <% } else { %>
            <span style="color:var(--color-text-muted);font-size:var(--text-sm)">&mdash; keine Benachrichtigung</span>
          <% } %>
        </td></tr>
        <% if (hasReminder) { %>
        <tr><th>&#9201; Erinnerung</th><td>
          <span id="reminderDisplay" style="font-size:var(--text-sm);color:var(--color-warning)">
            <strong><%= reminderDate %></strong>
          </span>
          <% if (user && user.role === 'admin') { %>
            <button class="btn btn-xs btn-ghost" id="clearReminderBtn"
              style="margin-left:var(--space-2);color:var(--color-text-muted)"
              title="Erinnerung löschen">&#10005;</button>
          <% } %>
        </td></tr>
        <% } %>
      </table>
      <% if (storung.beschreibung) { %>
        <div class="detail-beschreibung"><%= storung.beschreibung %></div>
      <% } %>
    </div>

    <% if (storung.attachments && storung.attachments.length > 0) { %>
    <div class="detail-card">
      <h3 style="margin-bottom:var(--space-3)">Anhänge (<%= storung.attachments.length %>)</h3>
      <div class="attachment-grid">
        <% storung.attachments.forEach(function(a) { %>
          <% if (a.mimetype && a.mimetype.startsWith('image/')) { %>
            <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer">
              <img
                src="/uploads/<%= encodeURIComponent(a.filename) %>"
                alt="<%= a.originalname %>"
                loading="lazy"
                width="200" height="150"
                style="object-fit:cover;border-radius:var(--radius-md);border:1px solid var(--color-border);max-height:150px;display:block">
            </a>
          <% } else if (a.mimetype && a.mimetype.startsWith('video/')) { %>
            <div style="border-radius:var(--radius-md);overflow:hidden;border:1px solid var(--color-border)">
              <video
                src="/uploads/<%= encodeURIComponent(a.filename) %>"
                controls
                preload="none"
                style="width:100%;max-width:320px;max-height:200px;display:block;background:#000"
                aria-label="<%= a.originalname %>">
                <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
                  &#127910; <%= a.originalname %> herunterladen
                </a>
              </video>
              <p style="font-size:var(--text-xs);color:var(--color-text-muted);padding:var(--space-1) var(--space-2);margin:0">
                <%= a.originalname %>
              </p>
            </div>
          <% } else { %>
            <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
              &#128206; <%= a.originalname %>
            </a>
          <% } %>
        <% }); %>
      </div>
    </div>
    <% } %>

    <div class="detail-card">
      <h3 style="margin-bottom:var(--space-3)">Statusverlauf</h3>
      <ol class="history-list" style="list-style:none">
        <% storung.history.forEach(function(h) { %>
          <li class="history-item">
            <span class="history-status"><%= STATUS_LABEL[h.status] || h.status %></span>
            <span class="history-by">von <%= h.changedBy %></span>
            <span class="history-date"><%= formatDate(h.changedAt) %></span>
            <% if (h.note) { %><span class="history-note">&bdquo;<%= h.note %>&ldquo;</span><% } %>
          </li>
        <% }); %>
      </ol>
    </div>

    <% if (user && user.role === 'admin') { %>
    <div class="detail-card" style="border-color:var(--color-primary)">
      <h3 style="margin-bottom:var(--space-3);color:var(--color-primary)">Admin-Aktionen</h3>

      <% if (storung.status === 'gesendet') { %>
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-4)">
        <button class="btn btn-sm status-change-btn"
          style="background:var(--color-active);color:#fff;border:none"
          data-id="<%= storung.id %>"
          data-target="bestaetigt"
          data-schwere="<%= storung.schwere %>"
          data-klasse="<%= storung.klasse || 'kfz' %>"
          data-mit-schwere="1"
          data-mit-klasse="1"
          data-title="&#10003; Störung bestätigen"
          data-desc="Störung wird als &raquo;In Bearbeitung&laquo; markiert. Schweregrad und Klasse optional korrigieren."
          data-label="Bestätigen"
          data-with-reminder="1">
          &#10003; Bestätigen
        </button>
        <button class="btn btn-sm status-change-btn"
          style="background:var(--color-primary);color:#fff;border:none"
          data-id="<%= storung.id %>"
          data-target="zurueckgewiesen"
          data-schwere="<%= storung.schwere %>"
          data-klasse="<%= storung.klasse || 'kfz' %>"
          data-title="&#10007; Ticket zurückweisen"
          data-desc="Das Ticket wird als &raquo;Zurückgewiesen&laquo; geschlossen."
          data-label="Zurückweisen">
          &#10007; Zurückweisen
        </button>
      </div>
      <% } %>
      <% if (storung.status === 'bestaetigt') { %>
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-4)">
        <button class="btn btn-sm status-change-btn"
          style="background:var(--color-done);color:#fff;border:none"
          data-id="<%= storung.id %>"
          data-target="erledigt"
          data-schwere="<%= storung.schwere %>"
          data-klasse="<%= storung.klasse || 'kfz' %>"
          data-title="&#10003; Störung erledigen"
          data-desc="Störung wird als &raquo;Erledigt&laquo; markiert."
          data-label="Erledigt setzen">
          &#10003; Erledigt
        </button>
        <button class="btn btn-xs btn-ghost status-change-btn"
          data-id="<%= storung.id %>"
          data-target="gesendet"
          data-schwere="<%= storung.schwere %>"
          data-klasse="<%= storung.klasse || 'kfz' %>"
          data-title="&#8617; Zurück zu Eingegangen"
          data-desc="Status wird auf &raquo;Eingegangen&laquo; zurückgesetzt."
          data-label="Zurücksetzen">
          &larrhk; Zurück zu Eingegangen
        </button>
        <button class="btn btn-xs btn-ghost" id="setReminderBtn"
          title="Erinnerung setzen" style="color:var(--color-warning)">
          &#9201; Erinnerung setzen
        </button>
      </div>
      <% } %>

      <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-3)">
        Löscht diese Störung <strong>vollständig</strong>: alle Anhänge und alle Datenbankeinträge.
      </p>
      <button class="btn btn-primary" id="deleteBtn"
        data-id="<%= storung.id %>"
        data-erledigt="<%= (storung.status === 'erledigt' || storung.status === 'zurueckgewiesen') ? '1' : '0' %>"
        style="background:var(--color-primary);border-color:var(--color-primary)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        Störung endgültig löschen
      </button>
    </div>
    <% } %>
  </div>
</div>

<% if (user && user.role === 'admin') { %>

<!-- Status-Änderungs-Modal -->
<div class="modal-backdrop" id="statusModal" hidden role="dialog" aria-modal="true" aria-labelledby="statusModalTitle" tabindex="-1">
  <div class="modal" style="max-width:520px">
    <h3 id="statusModalTitle" style="margin-bottom:var(--space-2)"></h3>
    <p id="statusModalDesc" style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)"></p>

    <!-- Klasse ändern (Issue #4) -->
    <div id="klasseRow" style="display:none;margin-bottom:var(--space-4)">
      <p style="font-size:var(--text-sm);font-weight:600;margin-bottom:var(--space-2)">Klasse anpassen:</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-2)">
        <button type="button" class="klasse-modal-btn" data-value="kfz"
          style="padding:var(--space-3);border:2px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);cursor:pointer;font-size:var(--text-sm);display:flex;align-items:center;gap:var(--space-2);transition:border-color 180ms,background 180ms">
          🚒 KFZ
        </button>
        <button type="button" class="klasse-modal-btn" data-value="geraet"
          style="padding:var(--space-3);border:2px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);cursor:pointer;font-size:var(--text-sm);display:flex;align-items:center;gap:var(--space-2);transition:border-color 180ms,background 180ms">
          🔧 Gerät
        </button>
      </div>
    </div>

    <!-- Schweregrad ändern -->
    <div id="schwereRow" style="display:none;margin-bottom:var(--space-4)">
      <p style="font-size:var(--text-sm);font-weight:600;margin-bottom:var(--space-2)">Schweregrad anpassen:</p>
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap">
        <% [['klein','🟢 Klein'],['normal','🟡 Normal'],['totalausfall','🔴 Totalausfall']].forEach(([v,l]) => { %>
          <button type="button" class="schwere-modal-btn" data-value="<%= v %>"
            style="padding:var(--space-2) var(--space-3);border:2px solid var(--color-border);border-radius:var(--radius-md);background:var(--color-surface);cursor:pointer;font-size:var(--text-sm);transition:border-color 180ms,background 180ms">
            <%= l %>
          </button>
        <% }); %>
      </div>
    </div>

    <!-- Erinnerung -->
    <div id="reminderRow" style="display:none;margin-bottom:var(--space-4)">
      <label style="font-size:var(--text-sm);font-weight:600;display:block;margin-bottom:var(--space-2)">Erinnerung setzen (optional):</label>
      <input type="datetime-local" id="modalReminderAt" class="form-control" style="max-width:260px">
    </div>

    <!-- Notiz -->
    <div class="form-group">
      <label class="form-label" for="statusNote">Notiz (optional)</label>
      <textarea class="form-control" id="statusNote" rows="2" maxlength="500"
        placeholder="Interne Bemerkung…" style="resize:vertical"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" id="statusCancelBtn">Abbrechen</button>
      <button class="btn btn-sm" id="statusConfirmBtn"
        style="background:var(--color-primary);border-color:var(--color-primary);color:#fff"></button>
    </div>
  </div>
</div>

<!-- Lösch-Modal -->
<div class="modal-backdrop" id="deleteModal" hidden role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle" tabindex="-1">
  <div class="modal" style="max-width:500px">
    <h3 id="deleteModalTitle" style="color:var(--color-primary);margin-bottom:var(--space-2)">&#9888;&#65039; Störung löschen</h3>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
      Diese Aktion ist <strong>nicht rückgängig</strong>. Bitte gib eine Begründung an.
    </p>
    <div class="form-group">
      <label class="form-label required" for="deleteGrund">Begründung</label>
      <textarea class="form-control" id="deleteGrund" rows="3"
        placeholder="z. B. Doppelmeldung – wurde bereits unter ID XY erfasst."
        maxlength="500" style="resize:vertical"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" id="deleteCancelBtn">Abbrechen</button>
      <button class="btn btn-primary" id="deleteConfirmBtn"
        style="background:var(--color-primary);border-color:var(--color-primary)">Endgültig löschen</button>
    </div>
  </div>
</div>

<!-- Erinnerungs-Modal -->
<div class="modal-backdrop" id="reminderModal" hidden role="dialog" aria-modal="true" aria-labelledby="reminderModalTitle" tabindex="-1">
  <div class="modal" style="max-width:420px">
    <h3 id="reminderModalTitle" style="margin-bottom:var(--space-2)">&#9201; Erinnerung setzen</h3>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
      Du erhältst eine E-Mail-Erinnerung zum gewählten Zeitpunkt mit dem aktuellen Ticket-Status.
    </p>
    <div class="form-group">
      <label class="form-label" for="reminderAtInput">Datum &amp; Uhrzeit</label>
      <input type="datetime-local" class="form-control" id="reminderAtInput" style="max-width:260px">
    </div>
    <div id="reminderFeedback" style="font-size:var(--text-xs);color:var(--color-error);margin-top:var(--space-2);min-height:1.2em"></div>
    <div class="modal-actions" style="margin-top:var(--space-4)">
      <button class="btn btn-ghost" id="reminderCancelBtn">Abbrechen</button>
      <button class="btn btn-sm" id="reminderSaveBtn"
        style="background:var(--color-warning);border-color:var(--color-warning);color:#fff">
        &#9201; Erinnerung speichern
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  const STOERUNG_ID = '<%= storung.id %>';

  // ── Status-Modal ────────────────────────────────────────────────
  let pendingAction = {};
  const statusModal    = document.getElementById('statusModal');
  const statusTitle    = document.getElementById('statusModalTitle');
  const statusDesc     = document.getElementById('statusModalDesc');
  const statusNote     = document.getElementById('statusNote');
  const statusConfirm  = document.getElementById('statusConfirmBtn');
  const statusCancel   = document.getElementById('statusCancelBtn');
  const schwereRow     = document.getElementById('schwereRow');
  const klasseRow      = document.getElementById('klasseRow');
  const reminderRow    = document.getElementById('reminderRow');

  // Schweregrad-Buttons im Modal
  let selectedSchwere = null;
  document.querySelectorAll('.schwere-modal-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.schwere-modal-btn').forEach(b => {
        b.style.borderColor = 'var(--color-border)';
        b.style.background  = 'var(--color-surface)';
      });
      btn.style.borderColor = 'var(--color-primary)';
      btn.style.background  = 'var(--color-primary-highlight)';
      selectedSchwere = btn.dataset.value;
    });
  });

  // Klasse-Buttons im Modal (Issue #4)
  let selectedKlasse = null;
  document.querySelectorAll('.klasse-modal-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.klasse-modal-btn').forEach(b => {
        b.style.borderColor = 'var(--color-border)';
        b.style.background  = 'var(--color-surface)';
      });
      btn.style.borderColor = 'var(--color-primary)';
      btn.style.background  = 'var(--color-primary-highlight)';
      selectedKlasse = btn.dataset.value;
    });
  });

  document.querySelectorAll('.status-change-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      pendingAction = {
        id:          btn.dataset.id,
        target:      btn.dataset.target,
        mitSchwere:  btn.dataset.mitSchwere === '1',
        mitKlasse:   btn.dataset.mitKlasse  === '1',
        withReminder: btn.dataset.withReminder === '1',
        label:       btn.dataset.label,
      };
      statusTitle.textContent    = btn.dataset.title;
      statusDesc.textContent     = btn.dataset.desc;
      statusConfirm.textContent  = btn.dataset.label;
      statusNote.value           = '';
      selectedSchwere            = btn.dataset.schwere || null;
      selectedKlasse             = btn.dataset.klasse  || null;

      // Schweregrad-Buttons vorauswählen
      schwereRow.style.display = pendingAction.mitSchwere ? 'block' : 'none';
      if (pendingAction.mitSchwere) {
        document.querySelectorAll('.schwere-modal-btn').forEach(b => {
          const active = b.dataset.value === selectedSchwere;
          b.style.borderColor = active ? 'var(--color-primary)' : 'var(--color-border)';
          b.style.background  = active ? 'var(--color-primary-highlight)' : 'var(--color-surface)';
        });
      }

      // Klasse-Buttons vorauswählen (Issue #4)
      klasseRow.style.display = pendingAction.mitKlasse ? 'block' : 'none';
      if (pendingAction.mitKlasse) {
        document.querySelectorAll('.klasse-modal-btn').forEach(b => {
          const active = b.dataset.value === selectedKlasse;
          b.style.borderColor = active ? 'var(--color-primary)' : 'var(--color-border)';
          b.style.background  = active ? 'var(--color-primary-highlight)' : 'var(--color-surface)';
        });
      }

      // Reminder
      reminderRow.style.display = pendingAction.withReminder ? 'block' : 'none';
      if (pendingAction.withReminder) {
        const d = new Date();
        d.setDate(d.getDate() + 1);
        const pad = n => String(n).padStart(2,'0');
        document.getElementById('modalReminderAt').value =
          `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T08:00`;
      }

      statusModal.hidden = false;
      setTimeout(() => statusNote.focus(), 50);
    });
  });

  if (statusCancel) statusCancel.addEventListener('click', () => { statusModal.hidden = true; });
  if (statusModal)  statusModal.addEventListener('click', e => { if (e.target === statusModal) statusModal.hidden = true; });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && statusModal && !statusModal.hidden) statusModal.hidden = true;
  });

  if (statusConfirm) {
    statusConfirm.addEventListener('click', async () => {
      statusConfirm.disabled = true;
      statusConfirm.textContent = 'Wird gespeichert…';
      const reminderAt = pendingAction.withReminder
        ? (document.getElementById('modalReminderAt').value || '')
        : '';
      try {
        const r = await fetch('/stoerung/' + pendingAction.id + '/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            status:    pendingAction.target,
            note:      statusNote.value.trim(),
            schwere:   selectedSchwere || '',
            klasse:    selectedKlasse  || '',
            reminderAt,
          }),
        });
        const data = await r.json();
        if (data.ok) { window.location.reload(); }
        else {
          alert('Fehler: ' + (data.error || 'Unbekannt'));
          statusConfirm.disabled = false;
          statusConfirm.textContent = pendingAction.label;
        }
      } catch(e) {
        alert('Netzwerkfehler.');
        statusConfirm.disabled = false;
        statusConfirm.textContent = pendingAction.label;
      }
    });
  }

  // ── Löschen ────────────────────────────────────────────────────
  const erledigt    = document.getElementById('deleteBtn')?.dataset.erledigt === '1';
  const deleteBtn   = document.getElementById('deleteBtn');
  const deleteModal = document.getElementById('de