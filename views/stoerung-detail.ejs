<%
function formatDate(iso) {
  return new Date(iso).toLocaleString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',timeZone:'Europe/Berlin'});
}
const STATUS_LABEL = {
  gesendet:        'Eingegangen',
  bestaetigt:      'In Bearbeitung',
  erledigt:        'Erledigt',
  zurueckgewiesen: 'Zurückgewiesen',
};
const SCHWERE = {
  klein:        { label: 'Klein',        icon: '\uD83D\uDFE2' },
  normal:       { label: 'Normal',       icon: '\uD83D\uDFE1' },
  totalausfall: { label: 'Totalausfall', icon: '\uD83D\uDD34' },
};
const isAdmin      = user && user.role === 'admin';
const hasReminder  = !!storung.reminderAt;
const reminderDate = hasReminder ? new Date(storung.reminderAt).toLocaleString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',timeZone:'Europe/Berlin'}) : null;
%>
<div class="form-container">
  <div class="form-header">
    <a href="/" class="back-link">&larr; Dashboard</a>
    <h1 class="page-title">Störung: <%= storung.fahrzeug %></h1>
  </div>

  <div class="detail-grid">

    <% if (isAdmin) { %>
    <!-- ═══════════════════════════════════════════════════════════════════
         ADMIN-ANSICHT: alle Felder + Statusverlauf + Anhänge + Aktionen
    ═══════════════════════════════════════════════════════════════════ -->
    <div class="detail-card">
      <table class="detail-table">
        <tr><th>Fahrzeug</th><td><strong><%= storung.fahrzeug %></strong></td></tr>
        <tr><th>Klasse</th><td>
          <span style="display:inline-block;padding:2px 10px;border-radius:12px;font-size:var(--text-xs);font-weight:700;background:var(--color-primary-highlight);color:var(--color-primary)">
            <%= storung.klasse === 'geraet' ? '\uD83D\uDD27 Gerät' : '\uD83D\uDE92 KFZ' %>
          </span>
        </td></tr>
        <tr><th>Schweregrad</th><td>
          <% const sw = SCHWERE[storung.schwere]; %>
          <% if (sw) { %>
            <span class="schwere-badge schwere-<%= storung.schwere.toLowerCase() %>"><%= sw.icon %> <%= sw.label %></span>
          <% } else { %>
            <span class="schwere-badge"><%= storung.schwere %></span>
          <% } %>
        </td></tr>
        <tr><th>Fehler</th><td><%= storung.fehlerBeschreibung %></td></tr>
        <tr><th>Status</th><td><strong><%= STATUS_LABEL[storung.status] || storung.status %></strong></td></tr>
        <tr><th>Gemeldet von</th><td><%= storung.melderName %> &ndash; <%= storung.melderKontakt %></td></tr>
        <tr><th>Erfasst von</th><td><%= storung.createdBy %></td></tr>
        <tr><th>Zeitpunkt</th><td><%= formatDate(storung.createdAt) %></td></tr>
        <tr><th>Meldungs-ID</th><td><code style="font-size:var(--text-xs)"><%= storung.id %></code></td></tr>
        <% if (hasReminder) { %>
        <tr><th>&#9201; Erinnerung</th><td>
          <span style="font-size:var(--text-sm);color:var(--color-warning)">
            <strong><%= reminderDate %></strong>
          </span>
          <% if (storung.reminderTo) { %>
            <span style="font-size:var(--text-xs);color:var(--color-text-muted);margin-left:var(--space-2)">
              &rarr; <%= storung.reminderTo %>
            </span>
          <% } %>
          <button class="btn btn-xs btn-ghost" id="clearReminderBtn"
            style="margin-left:var(--space-2);color:var(--color-text-muted)"
            title="Erinnerung löschen">&#10005;</button>
        </td></tr>
        <% } %>
      </table>
      <% if (storung.beschreibung) { %>
        <div class="detail-beschreibung"><%= storung.beschreibung %></div>
      <% } %>
    </div>

    <% if (storung.attachments && storung.attachments.length > 0) { %>
    <div class="detail-card">
      <h3 style="margin-bottom:var(--space-3)">Anhänge (<%= storung.attachments.length %>)</h3>
      <div class="attachment-grid">
        <% storung.attachments.forEach(function(a) { %>
          <% if (a.mimetype && a.mimetype.startsWith('image/')) { %>
            <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer">
              <img src="/uploads/<%= encodeURIComponent(a.filename) %>" alt="<%= a.originalname %>"
                loading="lazy" width="200" height="150"
                style="object-fit:cover;border-radius:var(--radius-md);border:1px solid var(--color-border);max-height:150px;display:block">
            </a>
          <% } else if (a.mimetype && a.mimetype.startsWith('video/')) { %>
            <div style="border-radius:var(--radius-md);overflow:hidden;border:1px solid var(--color-border)">
              <video src="/uploads/<%= encodeURIComponent(a.filename) %>" controls preload="none"
                style="width:100%;max-width:320px;max-height:200px;display:block;background:#000"
                aria-label="<%= a.originalname %>">
                <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
                  &#127910; <%= a.originalname %> herunterladen
                </a>
              </video>
              <p style="font-size:var(--text-xs);color:var(--color-text-muted);padding:var(--space-1) var(--space-2);margin:0"><%= a.originalname %></p>
            </div>
          <% } else { %>
            <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
              &#128206; <%= a.originalname %>
            </a>
          <% } %>
        <% }); %>
      </div>
    </div>
    <% } %>

    <div class="detail-card">
      <h3 style="margin-bottom:var(--space-3)">Statusverlauf</h3>
      <ol class="history-list" style="list-style:none">
        <% storung.history.forEach(function(h) { %>
          <li class="history-item">
            <span class="history-status">
              <% if (h.status === 'notiz') { %>&#128172; Info<% } else { %><%= STATUS_LABEL[h.status] || h.status %><% } %>
            </span>
            <span class="history-by">von <%= h.changedBy %></span>
            <span class="history-date"><%= formatDate(h.changedAt) %></span>
            <% if (h.note) { %><span class="history-note">&bdquo;<%= h.note %>&ldquo;</span><% } %>
          </li>
        <% }); %>
      </ol>
    </div>

    <div class="detail-card" style="border-color:var(--color-primary)">
      <h3 style="margin-bottom:var(--space-3);color:var(--color-primary)">Admin-Aktionen</h3>

      <% if (storung.status === 'gesendet') { %>
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-4)">
        <button class="btn btn-sm status-change-btn"
          style="background:var(--color-active);color:#fff;border:none"
          data-id="<%= storung.id %>"
          data-target="bestaetigt"
          data-schwere="<%= storung.schwere %>"
          data-klasse="<%= storung.klasse || 'kfz' %>"
          data-mit-schwere="1"
          data-mit-klasse="1"
          data-with-reminder="1"
          data-title="Störung bestätigen"
          data-desc="Störung wird als &raquo;In Bearbeitung&laquo; markiert. Schweregrad und Klasse optional korrigieren."
          data-label="Bestätigen">
          &#10003; Bestätigen
        </button>
        <button class="btn btn-sm status-change-btn"
          style="background:var(--color-primary);color:#fff;border:none"
          data-id="<%= storung.id %>"
          data-target="zurueckgewiesen"
          data-schwere="<%= storung.schwere %>"
          data-klasse="<%= storung.klasse || 'kfz' %>"
          data-mit-schwere="1"
          data-mit-klasse="1"
          data-title="Ticket zurückweisen"
          data-desc="Das Ticket wird als &raquo;Zurückgewiesen&laquo; geschlossen. Klasse und Schweregrad optional korrigieren."
          data-label="Zurückweisen">
          &#10007; Zurückweisen
        </button>
      </div>
      <% } %>

      <% if (storung.status === 'bestaetigt') { %>
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-4)">
        <!-- Erledigt: kein Klasse/Schwere-Picker – Werte wurden beim Bestätigen bereits geprüft -->
        <button class="btn btn-sm status-change-btn"
          style="background:var(--color-done);color:#fff;border:none"
          data-id="<%= storung.id %>"
          data-target="erledigt"
          data-title="Störung erledigen"
          data-desc="Störung wird als &raquo;Erledigt&laquo; markiert."
          data-label="Erledigt setzen">
          &#10003; Erledigt
        </button>
        <button class="btn btn-sm btn-ghost" id="addInfoBtn"
          title="Info zum Statusverlauf hinzufügen">
          &#128172; Info hinzufügen
        </button>
        <button class="btn btn-xs btn-ghost" id="setReminderBtn"
          title="Erinnerung setzen" style="color:var(--color-warning)">
          &#9201; Erinnerung setzen
        </button>
      </div>
      <% } %>

      <% if (storung.status === 'erledigt' || storung.status === 'zurueckgewiesen') { %>
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-4)">
        <button class="btn btn-xs btn-ghost status-change-btn"
          data-id="<%= storung.id %>"
          data-target="gesendet"
          data-schwere="<%= storung.schwere %>"
          data-klasse="<%= storung.klasse || 'kfz' %>"
          data-mit-schwere="1"
          data-mit-klasse="1"
          data-title="Wiederöffnen"
          data-desc="Status wird auf &raquo;Eingegangen&laquo; zurückgesetzt. Klasse und Schweregrad optional korrigieren."
          data-label="Wiederöffnen">
          &larrhk; Wiederöffnen
        </button>
      </div>
      <% } %>

      <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-3)">
        Löscht diese Störung <strong>vollständig</strong>: alle Anhänge und alle Datenbankeinträge.
      </p>
      <button class="btn btn-primary" id="deleteBtn"
        data-id="<%= storung.id %>"
        data-erledigt="<%= (storung.status === 'erledigt' || storung.status === 'zurueckgewiesen') ? '1' : '0' %>"
        style="background:var(--color-primary);border-color:var(--color-primary)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        Störung endgültig löschen
      </button>
    </div>

    <% } else { %>
    <!-- ═══════════════════════════════════════════════════════════════════
         MELDER-ANSICHT: nur Basisdaten, keine Kontaktinfos, kein Verlauf
    ═══════════════════════════════════════════════════════════════════ -->
    <div class="detail-card">
      <table class="detail-table">
        <tr><th>Meldungs-ID</th><td><code style="font-size:var(--text-xs)"><%= storung.id %></code></td></tr>
        <tr><th>Fahrzeug</th><td><strong><%= storung.fahrzeug %></strong></td></tr>
        <tr><th>Klasse</th><td>
          <span style="display:inline-block;padding:2px 10px;border-radius:12px;font-size:var(--text-xs);font-weight:700;background:var(--color-primary-highlight);color:var(--color-primary)">
            <%= storung.klasse === 'geraet' ? '\uD83D\uDD27 Gerät' : '\uD83D\uDE92 KFZ' %>
          </span>
        </td></tr>
        <tr><th>Schweregrad</th><td>
          <% const sw2 = SCHWERE[storung.schwere]; %>
          <% if (sw2) { %>
            <span class="schwere-badge schwere-<%= storung.schwere.toLowerCase() %>"><%= sw2.icon %> <%= sw2.label %></span>
          <% } else { %>
            <span class="schwere-badge"><%= storung.schwere %></span>
          <% } %>
        </td></tr>
        <tr><th>Fehler</th><td><%= storung.fehlerBeschreibung %></td></tr>
        <% if (storung.beschreibung) { %>
        <tr><th>Beschreibung</th><td><%= storung.beschreibung %></td></tr>
        <% } %>
        <tr><th>Gemeldet von</th><td><%= storung.melderName %></td></tr>
        <tr><th>Zeitpunkt</th><td><%= formatDate(storung.createdAt) %></td></tr>
        <tr><th>Status</th><td><strong><%= STATUS_LABEL[storung.status] || storung.status %></strong></td></tr>
      </table>
    </div>
    <% } %>

  </div>
</div>

<% if (isAdmin) { %>
<!-- Lösch-Modal -->
<div class="modal-backdrop" id="deleteModal" hidden role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle" tabindex="-1">
  <div class="modal" style="max-width:500px">
    <h3 id="deleteModalTitle" style="color:var(--color-primary);margin-bottom:var(--space-2)">&#9888;&#65039; Störung löschen</h3>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
      Diese Aktion ist <strong>nicht rükgängig</strong>. Bitte gib eine Begründung an.
    </p>
    <div class="form-group">
      <label class="form-label required" for="deleteGrund">Begründung</label>
      <textarea class="form-control" id="deleteGrund" rows="3"
        placeholder="z. B. Doppelmeldung – wurde bereits unter ID XY erfasst."
        maxlength="500" style="resize:vertical"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" id="deleteCancelBtn">Abbrechen</button>
      <button class="btn btn-primary" id="deleteConfirmBtn"
        style="background:var(--color-primary);border-color:var(--color-primary)">Endgültig löschen</button>
    </div>
  </div>
</div>

<!-- Erinnerungs-Modal -->
<div class="modal-backdrop" id="reminderModal" hidden role="dialog" aria-modal="true" aria-labelledby="reminderModalTitle" tabindex="-1">
  <div class="modal" style="max-width:420px">
    <h3 id="reminderModalTitle" style="margin-bottom:var(--space-2)">&#9201; Erinnerung setzen</h3>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
      Erinnerungen werden immer zur vollen Stunde zugestellt.
    </p>
    <div style="display:flex;gap:var(--space-3);align-items:flex-end;flex-wrap:wrap">
      <div class="form-group" style="margin-bottom:0">
        <label class="form-label" for="reminderDateInput">Datum</label>
        <input type="date" class="form-control" id="reminderDateInput" style="max-width:180px">
      </div>
      <div class="form-group" style="margin-bottom:0">
        <label class="form-label" for="reminderHourInput">Stunde</label>
        <select class="form-control" id="reminderHourInput" style="max-width:110px">
          <% for (var h = 0; h < 24; h++) { %>
            <option value="<%= h %>"><%= String(h).padStart(2,'0') %>:00 Uhr</option>
          <% } %>
        </select>
      </div>
    </div>
    <div id="reminderFeedback" style="font-size:var(--text-xs);color:var(--color-error);margin-top:var(--space-2);min-height:1.2em"></div>
    <div class="modal-actions" style="margin-top:var(--space-4)">
      <button class="btn btn-ghost" id="reminderCancelBtn">Abbrechen</button>
      <button class="btn btn-sm" id="reminderSaveBtn"
        style="background:var(--color-warning);border-color:var(--color-warning);color:#fff">
        &#9201; Erinnerung speichern
      </button>
    </div>
  </div>
</div>

<!-- Info-Notiz-Modal -->
<div class="modal-backdrop" id="infoModal" hidden role="dialog" aria-modal="true" aria-labelledby="infoModalTitle" tabindex="-1">
  <div class="modal" style="max-width:480px">
    <h3 id="infoModalTitle" style="margin-bottom:var(--space-2)">&#128172; Info hinzufügen</h3>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
      Der Eintrag wird unter deinem Namen im Statusverlauf gespeichert, ohne den Status zu ändern.
    </p>
    <div class="form-group">
      <label class="form-label required" for="infoText">Info / Notiz</label>
      <textarea class="form-control" id="infoText" rows="4"
        placeholder="z. B. Fahrzeug ist in der Werkstatt, Rückgabe voraussichtlich Freitag."
        maxlength="500" style="resize:vertical"></textarea>
    </div>
    <div id="infoFeedback" style="font-size:var(--text-xs);color:var(--color-error);margin-top:var(--space-2);min-height:1.2em"></div>
    <div class="modal-actions" style="margin-top:var(--space-4)">
      <button class="btn btn-ghost" id="infoCancelBtn">Abbrechen</button>
      <button class="btn btn-sm" id="infoSaveBtn"
        style="background:var(--color-active);border-color:var(--color-active);color:#fff">
        &#128172; Info speichern
      </button>
    </div>
  </div>
</div>
<% } %>

<script>
(function () {
  var IS_ADMIN = <%= isAdmin ? 'true' : 'false' %>;
  var STOERUNG_ID = '<%= storung.id %>';
  var CURRENT_USER = '<%= user && user.username ? user.username.replace(/'/g, "\\'") : '' %>';

  if (!IS_ADMIN) return;

  // ── LÖSCHEN ───────────────────────────────────────────────────────────────────
  var deleteBtn   = document.getElementById('deleteBtn');
  var deleteModal = document.getElementById('deleteModal');
  var cancelBtn   = document.getElementById('deleteCancelBtn');
  var confirmBtn  = document.getElementById('deleteConfirmBtn');
  var grundField  = document.getElementById('deleteGrund');

  if (deleteBtn) {
    var erledigt = deleteBtn.dataset.erledigt === '1';
    deleteBtn.addEventListener('click', function () {
      if (erledigt) {
        deleteBtn.disabled = true; deleteBtn.textContent = 'Lösche…';
        doDelete('Erledigt – automatisch bereinigt');
      } else {
        grundField.value = ''; deleteModal.hidden = false;
        setTimeout(function () { grundField.focus(); }, 50);
      }
    });
    cancelBtn.addEventListener('click', function () { deleteModal.hidden = true; });
    deleteModal.addEventListener('click', function (e) { if (e.target === deleteModal) deleteModal.hidden = true; });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !deleteModal.hidden) deleteModal.hidden = true; });
    confirmBtn.addEventListener('click', function () {
      var grund = grundField.value.trim();
      if (!grund) { grundField.style.borderColor = 'var(--color-primary)'; grundField.focus(); return; }
      grundField.style.borderColor = '';
      confirmBtn.disabled = true; confirmBtn.textContent = 'Lösche…';
      doDelete(grund);
    });
  }

  function doDelete(grund) {
    fetch('/stoerung/' + STOERUNG_ID + '/loeschen', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ grund: grund }),
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.ok) { window.location.href = '/?success=deleted'; }
      else {
        alert('Fehler: ' + (data.error || 'Unbekannt'));
        if (deleteBtn)  deleteBtn.disabled = false;
        if (confirmBtn) { confirmBtn.disabled = false; confirmBtn.textContent = 'Endgültig löschen'; }
      }
    })
    .catch(function () {
      alert('Netzwerkfehler.');
      if (deleteBtn) deleteBtn.disabled = false;
    });
  }

  // ── ERINNERUNG ────────────────────────────────────────────────────────────────
  var setReminderBtn    = document.getElementById('setReminderBtn');
  var reminderModal     = document.getElementById('reminderModal');
  var reminderDateInput = document.getElementById('reminderDateInput');
  var reminderHourInput = document.getElementById('reminderHourInput');
  var reminderFeedback  = document.getElementById('reminderFeedback');
  var reminderCancelBtn = document.getElementById('reminderCancelBtn');
  var reminderSaveBtn   = document.getElementById('reminderSaveBtn');

  function pad(n) { return String(n).padStart(2, '0'); }

  function initReminderDefaults() {
    var now = new Date();
    var defaultDate = new Date(now);
    var defaultHour = now.getHours() + 1;
    if (defaultHour >= 24) {
      defaultDate.setDate(defaultDate.getDate() + 1);
      defaultHour = 8;
    } else if (defaultHour < 8) {
      defaultHour = 8;
    }
    reminderDateInput.value = defaultDate.getFullYear() + '-' + pad(defaultDate.getMonth() + 1) + '-' + pad(defaultDate.getDate());
    reminderHourInput.value = String(defaultHour);
    var today = now.getFullYear() + '-' + pad(now.getMonth() + 1) + '-' + pad(now.getDate());
    reminderDateInput.min = today;
  }

  if (setReminderBtn) {
    setReminderBtn.addEventListener('click', function () {
      initReminderDefaults();
      reminderFeedback.textContent = '';
      reminderDateInput.style.borderColor = '';
      reminderModal.hidden = false;
      setTimeout(function () { reminderDateInput.focus(); }, 50);
    });
  }
  if (reminderCancelBtn) reminderCancelBtn.addEventListener('click', function () { reminderModal.hidden = true; });
  if (reminderModal) {
    reminderModal.addEventListener('click', function (e) { if (e.target === reminderModal) reminderModal.hidden = true; });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && reminderModal && !reminderModal.hidden) reminderModal.hidden = true; });
  }

  if (reminderSaveBtn) {
    reminderSaveBtn.addEventListener('click', function () {
      var dateVal = reminderDateInput.value;
      var hourVal = parseInt(reminderHourInput.value, 10);

      if (!dateVal) {
        reminderFeedback.textContent = 'Bitte ein Datum auswählen.';
        reminderDateInput.style.borderColor = 'var(--color-error)';
        return;
      }

      var parts = dateVal.split('-');
      var parsed = new Date(parseInt(parts[0],10), parseInt(parts[1],10)-1, parseInt(parts[2],10), hourVal, 0, 0, 0);

      if (parsed.getTime() <= Date.now() + 59 * 60 * 1000) {
        reminderFeedback.textContent = 'Der Zeitpunkt muss mindestens 1 Stunde in der Zukunft liegen.';
        reminderDateInput.style.borderColor = 'var(--color-error)';
        return;
      }

      reminderFeedback.textContent = '';
      reminderDateInput.style.borderColor = '';
      reminderSaveBtn.disabled = true;
      reminderSaveBtn.textContent = 'Speichere\u2026';

      fetch('/stoerung/' + STOERUNG_ID + '/reminder', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reminderAt: parsed.toISOString(), reminderTo: CURRENT_USER }),
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.ok) { reminderModal.hidden = true; window.location.reload(); }
        else {
          reminderFeedback.textContent = data.error || 'Fehler beim Speichern.';
          reminderDateInput.style.borderColor = 'var(--color-error)';
          reminderSaveBtn.disabled = false;
          reminderSaveBtn.innerHTML = '&#9201; Erinnerung speichern';
        }
      })
      .catch(function () {
        reminderFeedback.textContent = 'Netzwerkfehler.';
        reminderSaveBtn.disabled = false;
        reminderSaveBtn.innerHTML = '&#9201; Erinnerung speichern';
      });
    });
  }

  var clearReminderBtn = document.getElementById('clearReminderBtn');
  if (clearReminderBtn) {
    clearReminderBtn.addEventListener('click', function () {
      if (!confirm('Erinnerung wirklich löschen?')) return;
      fetch('/stoerung/' + STOERUNG_ID + '/reminder', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reminderAt: '', reminderTo: '' }),
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.ok) window.location.reload();
        else alert('Fehler: ' + (data.error || 'Unbekannt'));
      })
      .catch(function () { alert('Netzwerkfehler.'); });
    });
  }

  // ── INFO-NOTIZ ─────────────────────────────────────────────────────────────────
  var addInfoBtn    = document.getElementById('addInfoBtn');
  var infoModal     = document.getElementById('infoModal');
  var infoText      = document.getElementById('infoText');
  var infoFeedback  = document.getElementById('infoFeedback');
  var infoCancelBtn = document.getElementById('infoCancelBtn');
  var infoSaveBtn   = document.getElementById('infoSaveBtn');

  if (addInfoBtn && infoModal) {
    addInfoBtn.addEventListener('click', function () {
      infoText.value = '';
      infoFeedback.textContent = '';
      infoText.style.borderColor = '';
      infoModal.hidden = false;
      setTimeout(function () { infoText.focus(); }, 50);
    });
    infoCancelBtn.addEventListener('click', function () { infoModal.hidden = true; });
    infoModal.addEventListener('click', function (e) { if (e.target === infoModal) infoModal.hidden = true; });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !infoModal.hidden) infoModal.hidden = true; });

    infoSaveBtn.addEventListener('click', function () {
      var text = infoText.value.trim();
      if (!text) {
        infoFeedback.textContent = 'Bitte eine Info eingeben.';
        infoText.style.borderColor = 'var(--color-error)';
        infoText.focus();
        return;
      }
      infoFeedback.textContent = '';
      infoText.style.borderColor = '';
      infoSaveBtn.disabled = true;
      infoSaveBtn.textContent = 'Speichere\u2026';
      fetch('/stoerung/' + STOERUNG_ID + '/notiz', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notiz: text }),
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.ok) {
          infoModal.hidden = true;
          window.location.reload();
        } else {
          infoFeedback.textContent = data.error || 'Fehler beim Speichern.';
          infoText.style.borderColor = 'var(--color-error)';
          infoSaveBtn.disabled = false;
          infoSaveBtn.innerHTML = '&#128172; Info speichern';
        }
      })
      .catch(function () {
        infoFeedback.textContent = 'Netzwerkfehler.';
        infoSaveBtn.disabled = false;
        infoSaveBtn.innerHTML = '&#128172; Info speichern';
      });
    });
  }

})();
</script>
