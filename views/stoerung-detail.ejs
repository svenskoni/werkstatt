<%
function formatDate(iso) {
  return new Date(iso).toLocaleString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',timeZone:'Europe/Berlin'});
}
const benachrichtigt = Number(storung.melderBenachrichtigung) === 1;
const STATUS_LABEL = {
  gesendet:        'Eingegangen',
  bestaetigt:      'In Bearbeitung',
  erledigt:        'Erledigt',
  zurueckgewiesen: 'Zurückgewiesen',
};
%>
<div class="form-container">
  <div class="form-header">
    <a href="/" class="back-link">&larr; Dashboard</a>
    <h1 class="page-title">Störung: <%= storung.fahrzeug %></h1>
  </div>

  <div class="detail-grid">
    <div class="detail-card">
      <table class="detail-table">
        <tr><th>Fahrzeug</th><td><strong><%= storung.fahrzeug %></strong></td></tr>
        <tr><th>Schweregrad</th><td>
          <% const sw = SCHWERE[storung.schwere]; %>
          <% if (sw) { %>
            <span class="schwere-badge schwere-<%= storung.schwere.toLowerCase() %>"><%= sw.icon %> <%= sw.label %></span>
          <% } else { %>
            <span class="schwere-badge"><%= storung.schwere %></span>
          <% } %>
        </td></tr>
        <tr><th>Fehler</th><td><%= storung.fehlerBeschreibung %></td></tr>
        <tr><th>Status</th><td><strong><%= STATUS_LABEL[storung.status] || storung.status %></strong></td></tr>
        <tr><th>Gemeldet von</th><td><%= storung.melderName %> &ndash; <%= storung.melderKontakt %></td></tr>
        <tr><th>Erfasst von</th><td><%= storung.createdBy %></td></tr>
        <tr><th>Zeitpunkt</th><td><%= formatDate(storung.createdAt) %></td></tr>
        <tr><th>Meldungs-ID</th><td><code style="font-size:var(--text-xs)"><%= storung.id %></code></td></tr>
        <tr><th>Statusupdates</th><td>
          <% if (benachrichtigt) { %>
            <span style="color:var(--color-success);font-size:var(--text-sm)">&#10003; Melder wird benachrichtigt</span>
          <% } else { %>
            <span style="color:var(--color-text-muted);font-size:var(--text-sm)">&mdash; keine Benachrichtigung</span>
          <% } %>
        </td></tr>
      </table>
      <% if (storung.beschreibung) { %>
        <div class="detail-beschreibung"><%= storung.beschreibung %></div>
      <% } %>
    </div>

    <% if (storung.attachments && storung.attachments.length > 0) { %>
    <div class="detail-card">
      <h3 style="margin-bottom:var(--space-3)">Anhänge (<%= storung.attachments.length %>)</h3>
      <div class="attachment-grid">
        <% storung.attachments.forEach(function(a) { %>
          <% if (a.mimetype && a.mimetype.startsWith('image/')) { %>
            <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer">
              <img
                src="/uploads/<%= encodeURIComponent(a.filename) %>"
                alt="<%= a.originalname %>"
                loading="lazy"
                width="200" height="150"
                style="object-fit:cover;border-radius:var(--radius-md);border:1px solid var(--color-border);max-height:150px;display:block">
            </a>
          <% } else if (a.mimetype && a.mimetype.startsWith('video/')) { %>
            <div style="border-radius:var(--radius-md);overflow:hidden;border:1px solid var(--color-border)">
              <video
                src="/uploads/<%= encodeURIComponent(a.filename) %>"
                controls
                preload="none"
                style="width:100%;max-width:320px;max-height:200px;display:block;background:#000"
                aria-label="<%= a.originalname %>">
                <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
                  &#127910; <%= a.originalname %> herunterladen
                </a>
              </video>
              <p style="font-size:var(--text-xs);color:var(--color-text-muted);padding:var(--space-1) var(--space-2);margin:0">
                <%= a.originalname %>
              </p>
            </div>
          <% } else { %>
            <a href="/uploads/<%= encodeURIComponent(a.filename) %>" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
              &#128206; <%= a.originalname %>
            </a>
          <% } %>
        <% }); %>
      </div>
    </div>
    <% } %>

    <div class="detail-card">
      <h3 style="margin-bottom:var(--space-3)">Statusverlauf</h3>
      <ol class="history-list" style="list-style:none">
        <% storung.history.forEach(function(h) { %>
          <li class="history-item">
            <span class="history-status"><%= STATUS_LABEL[h.status] || h.status %></span>
            <span class="history-by">von <%= h.changedBy %></span>
            <span class="history-date"><%= formatDate(h.changedAt) %></span>
            <% if (h.note) { %><span class="history-note">&bdquo;<%= h.note %>&ldquo;</span><% } %>
          </li>
        <% }); %>
      </ol>
    </div>

    <% if (user && user.role === 'admin') { %>
    <div class="detail-card" style="border-color:var(--color-primary)">
      <h3 style="margin-bottom:var(--space-3);color:var(--color-primary)">Admin-Aktionen</h3>

      <% if (storung.status === 'gesendet') { %>
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-4)">
        <button class="btn btn-sm" id="bestaetigenBtn"
          style="background:var(--color-active);color:#fff;border:none">&#10003; Bestätigen</button>
        <button class="btn btn-sm" id="zurueckweisenBtn"
          style="background:var(--color-primary);color:#fff;border:none">&#10007; Zurückweisen</button>
      </div>
      <% } %>
      <% if (storung.status === 'bestaetigt') { %>
      <div style="display:flex;gap:var(--space-2);flex-wrap:wrap;margin-bottom:var(--space-4)">
        <button class="btn btn-sm" id="erledigtBtn"
          style="background:var(--color-done);color:#fff;border:none">&#10003; Erledigt</button>
        <button class="btn btn-xs btn-ghost" id="zurueckBtn">&larrhk; Zurück zu Eingegangen</button>
      </div>
      <% } %>

      <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-3)">
        Löscht diese Störung <strong>vollständig</strong>: alle Anhänge und alle Datenbankeinträge.
      </p>
      <button class="btn btn-primary" id="deleteBtn"
        data-id="<%= storung.id %>"
        data-erledigt="<%= (storung.status === 'erledigt' || storung.status === 'zurueckgewiesen') ? '1' : '0' %>"
        style="background:var(--color-primary);border-color:var(--color-primary)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        Störung endgültig löschen
      </button>
    </div>
    <% } %>
  </div>
</div>

<% if (user && user.role === 'admin') { %>
<div class="modal-backdrop" id="statusModal" hidden role="dialog" aria-modal="true" aria-labelledby="statusModalTitle" tabindex="-1">
  <div class="modal" style="max-width:500px">
    <h3 id="statusModalTitle" style="margin-bottom:var(--space-2)"></h3>
    <p id="statusModalDesc" style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)"></p>

    <%# Schweregrad-Änderung – nur beim Bestätigen (gesendet → bestaetigt) anzeigen %>
    <div id="schwereAendernWrap" style="display:none;margin-bottom:var(--space-4)">
      <label class="form-label" for="neuSchwereSelect" style="display:flex;align-items:center;gap:var(--space-2)">
        Schweregrad
        <span style="font-size:var(--text-xs);color:var(--color-text-muted);font-weight:400">(Admin kann korrigieren)</span>
      </label>
      <select class="form-control" id="neuSchwereSelect">
        <option value="klein">🟢 Klein</option>
        <option value="normal">🟡 Normal</option>
        <option value="schwer">🟠 Schwer</option>
        <option value="totalausfall">🔴 Totalausfall</option>
      </select>
    </div>

    <div class="form-group">
      <label class="form-label" for="statusNotiz">Notiz <span style="color:var(--color-text-faint)">(optional)</span></label>
      <textarea class="form-control" id="statusNotiz" rows="3"
        placeholder="z. B. Fahrzeug kommt diese Woche in die Werkstatt."
        maxlength="500" style="resize:vertical"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" id="statusCancelBtn">Abbrechen</button>
      <button class="btn btn-primary" id="statusConfirmBtn">Bestätigen</button>
    </div>
  </div>
</div>

<div class="modal-backdrop" id="deleteModal" hidden role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle" tabindex="-1">
  <div class="modal" style="max-width:500px">
    <h3 id="deleteModalTitle" style="color:var(--color-primary);margin-bottom:var(--space-2)">&#9888;&#65039; Störung löschen</h3>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
      Diese Aktion ist <strong>nicht rückgängig</strong>. Bitte gib eine Begründung an.
    </p>
    <div class="form-group">
      <label class="form-label required" for="deleteGrund">Begründung</label>
      <textarea class="form-control" id="deleteGrund" rows="3"
        placeholder="z. B. Doppelmeldung – wurde bereits unter ID XY erfasst."
        maxlength="500" style="resize:vertical"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" id="deleteCancelBtn">Abbrechen</button>
      <button class="btn btn-primary" id="deleteConfirmBtn"
        style="background:var(--color-primary);border-color:var(--color-primary)">Endgültig löschen</button>
    </div>
  </div>
</div>

<script>
(function() {
  const STOERUNG_ID      = '<%= storung.id %>';
  const AKTUELL_SCHWERE  = '<%= storung.schwere %>';

  const statusModal      = document.getElementById('statusModal');
  const statusTitle      = document.getElementById('statusModalTitle');
  const statusDesc       = document.getElementById('statusModalDesc');
  const statusNotiz      = document.getElementById('statusNotiz');
  const statusCancel     = document.getElementById('statusCancelBtn');
  const statusConfirm    = document.getElementById('statusConfirmBtn');
  const schwereWrap      = document.getElementById('schwereAendernWrap');
  const schwereSelect    = document.getElementById('neuSchwereSelect');
  let pendingTarget      = null;
  let showSchwere        = false;

  function openStatusModal(target, title, desc, confirmLabel, confirmStyle, mitSchwere) {
    pendingTarget = target;
    showSchwere   = !!mitSchwere;
    statusTitle.textContent   = title;
    statusDesc.textContent    = desc;
    statusConfirm.textContent = confirmLabel;
    statusConfirm.style.cssText = confirmStyle || '';
    statusNotiz.value = '';
    // Schweregrad-Dropdown: anzeigen/verbergen und auf aktuellen Wert setzen
    schwereWrap.style.display = showSchwere ? '' : 'none';
    if (showSchwere) schwereSelect.value = AKTUELL_SCHWERE;
    statusModal.hidden = false;
    setTimeout(() => (showSchwere ? schwereSelect : statusNotiz).focus(), 50);
  }

  statusCancel.addEventListener('click', () => { statusModal.hidden = true; });
  statusModal.addEventListener('click', e => { if (e.target === statusModal) statusModal.hidden = true; });

  statusConfirm.addEventListener('click', async () => {
    if (!pendingTarget) return;
    statusConfirm.disabled = true;
    statusConfirm.textContent = 'Wird gespeichert\u2026';
    const payload = {
      status: pendingTarget,
      notiz:  statusNotiz.value.trim() || null,
    };
    // Schwere nur mitsenden wenn Dropdown sichtbar und Wert geändert
    if (showSchwere && schwereSelect.value !== AKTUELL_SCHWERE) {
      payload.neuSchwere = schwereSelect.value;
    }
    try {
      const r = await fetch('/stoerung/' + STOERUNG_ID + '/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await r.json();
      if (data.ok) { window.location.reload(); }
      else { alert('Fehler: ' + (data.error || 'Unbekannt')); statusConfirm.disabled = false; statusConfirm.textContent = confirmLabel; }
    } catch(e) {
      alert('Netzwerkfehler.');
      statusConfirm.disabled = false;
    }
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      if (!statusModal.hidden) statusModal.hidden = true;
      if (!deleteModal.hidden) deleteModal.hidden = true;
    }
  });

  const bestaetigenBtn   = document.getElementById('bestaetigenBtn');
  const zurueckweisenBtn = document.getElementById('zurueckweisenBtn');
  const erledigtBtn      = document.getElementById('erledigtBtn');
  const zurueckBtn       = document.getElementById('zurueckBtn');

  // Bestätigen: MIT Schweregrad-Dropdown
  if (bestaetigenBtn) bestaetigenBtn.addEventListener('click', () =>
    openStatusModal('bestaetigt', '\u2713 St\u00f6rung best\u00e4tigen',
      'Die St\u00f6rung wird als \u201eIn Bearbeitung\u201c markiert. Optional den Schweregrad korrigieren.',
      'Best\u00e4tigen', 'background:var(--color-active);color:#fff;border:none', true));

  // Zurückweisen: OHNE Schweregrad
  if (zurueckweisenBtn) zurueckweisenBtn.addEventListener('click', () =>
    openStatusModal('zurueckgewiesen', '\u2715 Ticket zur\u00fcckweisen',
      'Das Ticket wird als \u201eZur\u00fcckgewiesen\u201c geschlossen. Optional eine Begr\u00fcndung angeben.',
      'Zur\u00fcckweisen', 'background:var(--color-primary);color:#fff;border:none', false));

  // Erledigt: OHNE Schweregrad
  if (erledigtBtn) erledigtBtn.addEventListener('click', () =>
    openStatusModal('erledigt', '\u2713 St\u00f6rung erledigen',
      'Die St\u00f6rung wird als \u201eErledigt\u201c markiert.',
      'Erledigt setzen', 'background:var(--color-done);color:#fff;border:none', false));

  // Zurück zu Eingegangen: OHNE Schweregrad
  if (zurueckBtn) zurueckBtn.addEventListener('click', () =>
    openStatusModal('gesendet', '\u21a9 Zur\u00fcck zu Eingegangen',
      'Der Status wird auf \u201eEingegangen\u201c zur\u00fcckgesetzt.',
      'Zur\u00fccksetzen', '', false));

  const deleteBtn        = document.getElementById('deleteBtn');
  const deleteModal      = document.getElementById('deleteModal');
  const deleteCancelBtn  = document.getElementById('deleteCancelBtn');
  const deleteConfirmBtn = document.getElementById('deleteConfirmBtn');
  const grundField       = document.getElementById('deleteGrund');
  if (!deleteBtn) return;
  const erledigt = deleteBtn.dataset.erledigt === '1';

  deleteBtn.addEventListener('click', () => {
    if (erledigt) {
      deleteBtn.disabled = true;
      deleteBtn.textContent = 'L\u00f6sche\u2026';
      doDelete('Erledigt \u2013 automatisch bereinigt');
    } else {
      grundField.value = '';
      deleteModal.hidden = false;
      setTimeout(() => grundField.focus(), 50);
    }
  });

  deleteCancelBtn.addEventListener('click', () => { deleteModal.hidden = true; });
  deleteModal.addEventListener('click', e => { if (e.target === deleteModal) deleteModal.hidden = true; });

  deleteConfirmBtn.addEventListener('click', () => {
    const grund = grundField.value.trim();
    if (!grund) { grundField.style.borderColor = 'var(--color-primary)'; grundField.focus(); return; }
    grundField.style.borderColor = '';
    deleteConfirmBtn.disabled = true;
    deleteConfirmBtn.textContent = 'L\u00f6sche\u2026';
    doDelete(grund);
  });

  async function doDelete(grund) {
    try {
      const r = await fetch('/stoerung/' + STOERUNG_ID + '/loeschen', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ grund }),
      });
      const data = await r.json();
      if (data.ok) { window.location.href = '/?success=deleted'; }
      else {
        alert('Fehler: ' + (data.error || 'Unbekannt'));
        deleteBtn.disabled = false;
        if (deleteConfirmBtn) { deleteConfirmBtn.disabled = false; deleteConfirmBtn.textContent = 'Endg\u00fcltig l\u00f6schen'; }
      }
    } catch (e) {
      alert('Netzwerkfehler.');
      deleteBtn.disabled = false;
    }
  }
})();
</script>
<% } %>
