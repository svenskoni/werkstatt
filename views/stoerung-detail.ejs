<%
function formatDate(iso) {
  return new Date(iso).toLocaleString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit',timeZone:'Europe/Berlin'});
}
// libsql liefert Integer-Felder manchmal als String – explizit casten
const benachrichtigt = Number(storung.melderBenachrichtigung) === 1;
%>
<div class="form-container">
  <div class="form-header">
    <a href="/" class="back-link">← Dashboard</a>
    <h1 class="page-title">Störung: <%= storung.fahrzeug %></h1>
  </div>

  <div class="detail-grid">
    <div class="detail-card">
      <table class="detail-table">
        <tr><th>Fahrzeug</th><td><strong><%= storung.fahrzeug %></strong></td></tr>
        <tr><th>Schweregrad</th><td>
          <% const sw = SCHWERE[storung.schwere]; %>
          <% if (sw) { %>
            <span class="schwere-badge schwere-<%= storung.schwere.toLowerCase() %>"><%= sw.icon %> <%= sw.label %></span>
          <% } else { %>
            <span class="schwere-badge"><%= storung.schwere %></span>
          <% } %>
        </td></tr>
        <tr><th>Fehler</th><td><%= storung.fehlerBeschreibung %></td></tr>
        <tr><th>Status</th><td><strong><%= storung.status === 'gesendet' ? 'Eingegangen' : storung.status === 'bestaetigt' ? 'In Bearbeitung' : 'Erledigt' %></strong></td></tr>
        <tr><th>Gemeldet von</th><td><%= storung.melderName %> &ndash; <%= storung.melderKontakt %></td></tr>
        <tr><th>Erfasst von</th><td><%= storung.createdBy %></td></tr>
        <tr><th>Zeitpunkt</th><td><%= formatDate(storung.createdAt) %></td></tr>
        <tr><th>Meldungs-ID</th><td><code style="font-size:var(--text-xs)"><%= storung.id %></code></td></tr>
        <tr><th>Statusupdates</th><td>
          <% if (benachrichtigt) { %>
            <span style="color:var(--color-success);font-size:var(--text-sm)">✅ Melder wird benachrichtigt</span>
          <% } else { %>
            <span style="color:var(--color-text-muted);font-size:var(--text-sm)">&mdash; keine Benachrichtigung</span>
          <% } %>
        </td></tr>
      </table>
      <% if (storung.beschreibung) { %>
        <div class="detail-beschreibung"><%= storung.beschreibung %></div>
      <% } %>
    </div>

    <% if (storung.attachments.length > 0) { %>
    <div class="detail-card">
      <h3 style="margin-bottom:var(--space-3)">Anhänge (<%= storung.attachments.length %>)</h3>
      <div class="attachment-grid">
        <% storung.attachments.forEach(a => { %>
          <% if (a.mimetype.startsWith('image/')) { %>
            <a href="/uploads/<%= a.filename %>" target="_blank" rel="noopener">
              <img src="/uploads/<%= a.filename %>" alt="<%= a.originalname %>" loading="lazy" width="200" height="150" style="object-fit:cover;border-radius:var(--radius-md);border:1px solid var(--color-border)">
            </a>
          <% } else { %>
            <a href="/uploads/<%= a.filename %>" target="_blank" rel="noopener" class="btn btn-ghost">🎦 <%= a.originalname %></a>
          <% } %>
        <% }); %>
      </div>
    </div>
    <% } %>

    <div class="detail-card">
      <h3 style="margin-bottom:var(--space-3)">Statusverlauf</h3>
      <ol class="history-list" style="list-style:none">
        <% storung.history.forEach(h => { %>
          <li class="history-item">
            <span class="history-status"><%= h.status === 'gesendet' ? 'Eingegangen' : h.status === 'bestaetigt' ? 'In Bearbeitung' : 'Erledigt' %></span>
            <span class="history-by">von <%= h.changedBy %></span>
            <span class="history-date"><%= formatDate(h.changedAt) %></span>
            <% if (h.note) { %><span class="history-note">„<%= h.note %>“</span><% } %>
          </li>
        <% }); %>
      </ol>
    </div>

    <% if (user && user.role === 'admin') { %>
    <div class="detail-card" style="border-color:var(--color-primary)">
      <h3 style="margin-bottom:var(--space-2);color:var(--color-primary)">⚠️ Gefahrenbereich (Admin)</h3>
      <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
        Löscht diese Störung <strong>vollständig</strong>: alle Anhänge vom Server und alle Datenbankeinträge.
        <% if (storung.status === 'erledigt') { %>
          <br><span style="color:var(--color-success)">&#10003; Status ist „Erledigt“ – keine Begründung erforderlich.</span>
        <% } else { %>
          <br>Bei nicht-erledigten Störungen ist eine Begründung erforderlich.
        <% } %>
      </p>
      <button class="btn btn-primary" id="deleteBtn" data-id="<%= storung.id %>" data-erledigt="<%= storung.status === 'erledigt' ? '1' : '0' %>"
        style="background:var(--color-primary);border-color:var(--color-primary)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        Störung endgültig löschen
      </button>
    </div>
    <% } %>
  </div>
</div>

<% if (user && user.role === 'admin') { %>
<div class="modal-backdrop" id="deleteModal" hidden role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle" tabindex="-1">
  <div class="modal" style="max-width:500px">
    <h3 id="deleteModalTitle" style="color:var(--color-primary);margin-bottom:var(--space-2)">⚠️ Störung löschen</h3>
    <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-4)">
      Diese Aktion ist <strong>nicht rükgängig</strong>. Bitte gib eine Begründung an.
    </p>
    <div class="form-group">
      <label class="form-label required" for="deleteGrund">Begründung</label>
      <textarea class="form-control" id="deleteGrund" rows="3"
        placeholder="z. B. Doppelmeldung – wurde bereits unter ID XY erfasst."
        maxlength="500" style="resize:vertical"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" id="deleteCancelBtn">Abbrechen</button>
      <button class="btn btn-primary" id="deleteConfirmBtn"
        style="background:var(--color-primary);border-color:var(--color-primary)">Endgültig löschen</button>
    </div>
  </div>
</div>

<script>
(function() {
  const deleteBtn   = document.getElementById('deleteBtn');
  const deleteModal = document.getElementById('deleteModal');
  const cancelBtn   = document.getElementById('deleteCancelBtn');
  const confirmBtn  = document.getElementById('deleteConfirmBtn');
  const grundField  = document.getElementById('deleteGrund');
  if (!deleteBtn) return;
  const stoerungId  = deleteBtn.dataset.id;
  const erledigt    = deleteBtn.dataset.erledigt === '1';

  deleteBtn.addEventListener('click', () => {
    if (erledigt) {
      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Lösche…';
      doDelete('Erledigt – automatisch bereinigt');
    } else {
      grundField.value = '';
      deleteModal.hidden = false;
      deleteModal.focus();
      grundField.focus();
    }
  });

  cancelBtn.addEventListener('click', () => { deleteModal.hidden = true; });
  deleteModal.addEventListener('click', e => { if (e.target === deleteModal) deleteModal.hidden = true; });
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && !deleteModal.hidden) deleteModal.hidden = true; });

  confirmBtn.addEventListener('click', () => {
    const grund = grundField.value.trim();
    if (!grund) { grundField.style.borderColor = 'var(--color-primary)'; grundField.focus(); return; }
    grundField.style.borderColor = '';
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Lösche…';
    doDelete(grund);
  });

  async function doDelete(grund) {
    try {
      const r = await fetch('/stoerung/' + stoerungId + '/loeschen', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ grund }),
      });
      const data = await r.json();
      if (data.ok) {
        window.location.href = '/?success=deleted';
      } else {
        alert('Fehler: ' + (data.error || 'Unbekannt'));
        deleteBtn.disabled = false;
        deleteBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg> Störung endgültig löschen';
        if (confirmBtn) { confirmBtn.disabled = false; confirmBtn.textContent = 'Endgültig löschen'; }
      }
    } catch (e) {
      alert('Netzwerkfehler.');
      deleteBtn.disabled = false;
    }
  }
})();
</script>
<% } %>
