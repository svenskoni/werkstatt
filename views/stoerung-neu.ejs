<div class="form-container">
  <div class="form-header">
    <a href="/" class="back-link">← Dashboard</a>
    <h1 class="page-title">🚨 Neue Störung melden</h1>
  </div>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error" role="alert">
      <ul class="error-list">
        <% errors.forEach(e => { %><li><%= e %></li><% }); %>
      </ul>
    </div>
  <% } %>

  <form class="stoerung-form" action="/stoerung/neu" method="POST" enctype="multipart/form-data" novalidate>

    <!-- Melderdaten -->
    <div class="form-group">
      <label class="form-label required" for="melderName">Name des Melders</label>
      <input type="text" id="melderName" name="melderName" class="form-control"
        placeholder="Vor- und Nachname" value="<%= old.melderName || '' %>"
        required minlength="3" maxlength="100" autocomplete="name">
    </div>

    <div class="form-group">
      <label class="form-label required" for="melderHandy">Handy</label>
      <input type="tel" id="melderHandy" name="melderHandy" class="form-control"
        placeholder="Mobilnummer" value="<%= old.melderHandy || '' %>"
        minlength="5" maxlength="40" autocomplete="tel">
      <span class="form-hint">Handy oder E‑Mail muss ausgefüllt sein.</span>
    </div>

    <div class="form-group">
      <label class="form-label" for="melderMail">E‑Mail</label>
      <input type="email" id="melderMail" name="melderMail" class="form-control"
        placeholder="E‑Mailadresse" value="<%= old.melderMail || '' %>"
        maxlength="120" autocomplete="email">
    </div>

    <!-- Benachrichtigung opt-in (nur sichtbar wenn E-Mail vorhanden) -->
    <div class="form-group" id="benachrichtigungGroup" style="display:none">
      <div class="toggle-card" id="benachrichtigungToggle" role="checkbox" aria-checked="false" tabindex="0"
        style="display:flex;align-items:center;gap:var(--space-3);padding:var(--space-4);border-radius:var(--radius-md);border:2px solid var(--color-border);cursor:pointer;background:var(--color-surface);transition:border-color var(--transition-interactive),background var(--transition-interactive)">
        <div style="font-size:22px;line-height:1">🔔</div>
        <div style="flex:1">
          <div style="font-weight:600;font-size:var(--text-sm)">Ich möchte bei Statusänderungen informiert werden</div>
          <div style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:2px">Sie erhalten eine E-Mail wenn sich der Status ändert (z. B. „In Bearbeitung“, „Erledigt“)</div>
        </div>
        <div class="toggle-check" style="width:22px;height:22px;border-radius:50%;border:2px solid var(--color-border);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0"></div>
      </div>
      <input type="hidden" name="melderBenachrichtigung" id="melderBenachrichtigungInput" value="0">
    </div>

    <!-- Fahrzeug -->
    <div class="form-group">
      <label class="form-label required" for="fahrzeug">Fahrzeug</label>
      <select id="fahrzeug" name="fahrzeug" class="form-control form-select" required>
        <option value="" disabled <%= !old.fahrzeug ? 'selected' : '' %>>Fahrzeug wählen…</option>
        <% VEHICLES.forEach(v => { %>
          <option value="<%= v %>" <%= old.fahrzeug === v ? 'selected' : '' %>><%= v %></option>
        <% }); %>
      </select>
    </div>

    <!-- Schweregrad -->
    <div class="form-group">
      <fieldset class="schwere-fieldset">
        <legend class="form-label required">Schweregrad</legend>
        <div class="schwere-grid">
          <% [['klein','Klein','🟢','Kleinere Schäden, Fahrzeug einsatzbereit'],['normal','Normal','🟡','Eingeschränkte Funktion'],['schwer','Schwer','🟠','Erheblicher Schaden'],['totalausfall','Totalausfall','🔴','Fahrzeug nicht einsatzbereit']].forEach(([val,label,icon,hint]) => { %>
          <label class="schwere-option <%= old.schwere === val ? 'checked' : '' %>">
            <input type="radio" name="schwere" value="<%= val %>" <%= old.schwere === val ? 'checked' : '' %> required>
            <span class="schwere-icon"><%= icon %></span>
            <span class="schwere-label"><%= label %></span>
            <span class="form-hint" style="margin:0;text-align:center"><%= hint %></span>
          </label>
          <% }); %>
        </div>
      </fieldset>
    </div>

    <!-- Fehlerbeschreibung -->
    <div class="form-group">
      <label class="form-label required" for="fehlerBeschreibung">Fehlerbeschreibung</label>
      <input type="text" id="fehlerBeschreibung" name="fehlerBeschreibung" class="form-control"
        placeholder="Kurze, prägnante Beschreibung des Fehlers…"
        value="<%= old.fehlerBeschreibung || '' %>"
        required minlength="6" maxlength="200" autocomplete="off">
      <div id="similarWarning" class="similar-warning" hidden>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span id="similarText">Ähnliche offene Störungen gefunden.</span>
      </div>
      <span class="form-hint">Mind. 6 Zeichen &ndash; wird mit offenen Störungen dieses Fahrzeugs abgeglichen.</span>
    </div>

    <!-- Detailbeschreibung -->
    <div class="form-group">
      <label class="form-label" for="beschreibung">Detailbeschreibung</label>
      <textarea id="beschreibung" name="beschreibung" class="form-control" rows="4"
        placeholder="Wann aufgetreten? Unter welchen Umständen?…"
        maxlength="2000"><%= old.beschreibung || '' %></textarea>
    </div>

    <!-- Upload -->
    <div class="form-group">
      <label class="form-label">Fotos / Videos (max. <%= process.env.MAX_UPLOAD_MB || 8 %> MB pro Datei)</label>
      <div class="upload-area" id="uploadArea">
        <input type="file" id="attachments" name="attachments" multiple accept="image/*,video/*" class="upload-input">
        <div class="upload-placeholder" id="uploadPlaceholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Klicken oder Dateien hierher ziehen</span>
          <span class="upload-hint">JPG, PNG, GIF, WebP, MP4, MOV &middot; max. 6 Dateien</span>
          <button type="button" class="btn btn-sm btn-ghost" id="uploadButton">Dateien auswählen…</button>
        </div>
        <div class="file-preview" id="filePreview" hidden></div>
      </div>
    </div>

    <div class="form-actions">
      <a href="/" class="btn btn-ghost">Abbrechen</a>
      <button type="submit" class="btn btn-primary btn-lg">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Störung melden
      </button>
    </div>
  </form>
</div>

<script>
// Schweregrad
document.querySelectorAll('.schwere-option').forEach(opt => {
  opt.addEventListener('click', () => {
    document.querySelectorAll('.schwere-option').forEach(o => o.classList.remove('checked'));
    opt.classList.add('checked');
  });
});

// Upload
const area = document.getElementById('uploadArea');
const input = document.getElementById('attachments');
const preview = document.getElementById('filePreview');
const placeholder = document.getElementById('uploadPlaceholder');
const uploadButton = document.getElementById('uploadButton');
if (uploadButton) uploadButton.addEventListener('click', e => { e.stopPropagation(); input.click(); });
area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('drag-over'); });
area.addEventListener('dragleave', () => area.classList.remove('drag-over'));
area.addEventListener('drop', e => {
  e.preventDefault(); area.classList.remove('drag-over');
  const dt = new DataTransfer();
  [...e.dataTransfer.files].forEach(f => dt.items.add(f));
  input.files = dt.files; showPreview(input.files);
});
input.addEventListener('change', () => showPreview(input.files));
function showPreview(files) {
  preview.innerHTML = '';
  if (!files.length) { preview.hidden = true; placeholder.hidden = false; return; }
  preview.hidden = false; placeholder.hidden = true;
  [...files].forEach(f => {
    const item = document.createElement('div'); item.className = 'file-item';
    const MAX = (parseInt('<%= process.env.MAX_UPLOAD_MB || 8 %>') * 1024 * 1024);
    if (f.type.startsWith('image/')) {
      const img = document.createElement('img');
      img.className = 'file-thumb'; img.alt = f.name; img.width = 100; img.height = 75;
      img.src = URL.createObjectURL(f); item.appendChild(img);
    } else {
      const icon = document.createElement('div'); icon.className = 'file-icon'; icon.textContent = '🎬'; item.appendChild(icon);
    }
    const name = document.createElement('span'); name.className = 'file-name'; name.textContent = f.name; item.appendChild(name);
    const size = document.createElement('span'); size.className = 'file-size';
    size.textContent = f.size > MAX ? '⚠️ zu groß' : (f.size/1024).toFixed(0)+' KB';
    if (f.size > MAX) size.style.color = 'var(--color-primary)';
    item.appendChild(size); preview.appendChild(item);
  });
}

// Ähnliche Fehler – nur im gewählten Fahrzeug, ab 6 Zeichen
const fehlerInput   = document.getElementById('fehlerBeschreibung');
const fahrzeugSelect = document.getElementById('fahrzeug');
const warning       = document.getElementById('similarWarning');
const warningText   = document.getElementById('similarText');
let debounceTimer;

function checkSimilar() {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(async () => {
    const q        = fehlerInput.value.trim();
    const fahrzeug = fahrzeugSelect.value;
    if (q.length < 6) { warning.hidden = true; return; }
    try {
      const params = new URLSearchParams({ q });
      if (fahrzeug) params.set('fahrzeug', fahrzeug);
      const r = await fetch('/api/similar?' + params.toString());
      const data = await r.json();
      if (data.length > 0) {
        warningText.textContent = data.length + ' ähnliche offene Störung(en) bei ' +
          (fahrzeug || 'diesem Fahrzeug') + ': ' +
          data.map(d => d.fehler).join(' | ');
        warning.hidden = false;
      } else { warning.hidden = true; }
    } catch { warning.hidden = true; }
  }, 400);
}

fehlerInput.addEventListener('input', checkSimilar);
fahrzeugSelect.addEventListener('change', checkSimilar);

// Benachrichtigungs-Toggle
const mailInput  = document.getElementById('melderMail');
const benGrp     = document.getElementById('benachrichtigungGroup');
const benToggle  = document.getElementById('benachrichtigungToggle');
const benInput   = document.getElementById('melderBenachrichtigungInput');
const benCheck   = benToggle.querySelector('.toggle-check');
let benActive    = false;

function updateBenVisible() {
  const hasMail = mailInput.value.trim().includes('@');
  benGrp.style.display = hasMail ? 'block' : 'none';
  if (!hasMail) { benActive = false; benInput.value = '0'; applyBenState(); }
}
function applyBenState() {
  if (benActive) {
    benToggle.style.borderColor = 'var(--color-primary)';
    benToggle.style.background  = 'oklch(from var(--color-primary) l c h / 0.07)';
    benCheck.textContent = '✓'; benCheck.style.borderColor = 'var(--color-primary)';
    benCheck.style.color = 'var(--color-primary)'; benCheck.style.fontWeight = 'bold';
    benToggle.setAttribute('aria-checked', 'true');
  } else {
    benToggle.style.borderColor = 'var(--color-border)';
    benToggle.style.background  = 'var(--color-surface)';
    benCheck.textContent = ''; benCheck.style.borderColor = 'var(--color-border)';
    benToggle.setAttribute('aria-checked', 'false');
  }
}
benToggle.addEventListener('click', () => { benActive = !benActive; benInput.value = benActive ? '1' : '0'; applyBenState(); });
benToggle.addEventListener('keydown', e => { if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); benToggle.click(); } });
mailInput.addEventListener('input', updateBenVisible);
updateBenVisible();
</script>
