<div class="form-container">
  <div class="form-header">
    <a href="/" class="back-link">← Dashboard</a>
    <h1 class="page-title">🚨 Neue Störung melden</h1>
  </div>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error" role="alert">
      <ul class="error-list">
        <% errors.forEach(e => { %><li><%= e %></li><% }); %>
      </ul>
    </div>
  <% } %>

  <div id="clientErrors" class="alert alert-error" role="alert" style="display:none">
    <ul id="clientErrorList" class="error-list"></ul>
  </div>

  <form class="stoerung-form" id="stoerungForm" action="/stoerung/neu" method="POST" enctype="multipart/form-data" novalidate>

    <!-- Melderdaten -->
    <div class="form-group">
      <label class="form-label required" for="melderName">Name des Melders</label>
      <input type="text" id="melderName" name="melderName" class="form-control"
        placeholder="Vor- und Nachname" value="<%= old.melderName || '' %>"
        required minlength="3" maxlength="100" autocomplete="name">
    </div>

    <div class="form-group">
      <label class="form-label required" for="melderHandy">Handy</label>
      <input type="tel" id="melderHandy" name="melderHandy" class="form-control"
        placeholder="Mobilnummer" value="<%= old.melderHandy || '' %>"
        minlength="5" maxlength="40" autocomplete="tel">
      <span class="form-hint">Handy oder E‑Mail muss ausgefüllt sein.</span>
    </div>

    <div class="form-group">
      <label class="form-label" for="melderMail">E‑Mail</label>
      <input type="email" id="melderMail" name="melderMail" class="form-control"
        placeholder="E‑Mailadresse" value="<%= old.melderMail || '' %>"
        maxlength="120" autocomplete="email">
    </div>

    <!-- Fahrzeug -->
    <div class="form-group">
      <label class="form-label required" for="fahrzeug">Fahrzeug</label>
      <select id="fahrzeug" name="fahrzeug" class="form-control form-select" required>
        <option value="" disabled <%= !old.fahrzeug ? 'selected' : '' %>>Fahrzeug wählen…</option>
        <% VEHICLES.forEach(v => { %>
          <option value="<%= v %>" <%= old.fahrzeug === v ? 'selected' : '' %>><%= v %></option>
        <% }); %>
      </select>
    </div>

    <!-- Klasse -->
    <div class="form-group">
      <fieldset class="klasse-fieldset">
        <legend class="form-label required">Art der Störung</legend>
        <input type="hidden" id="klasseInput" name="klasse" value="<%= old.klasse || 'kfz' %>">
        <div class="klasse-grid">
          <button type="button" class="klasse-option <%= (!old.klasse || old.klasse === 'kfz') ? 'active' : '' %>" data-value="kfz">
            <span class="klasse-label">KFZ</span>
            <span class="form-hint" style="margin:0;text-align:center">Fahrzeugschaden, Karosserie, Motor</span>
          </button>
          <button type="button" class="klasse-option <%= old.klasse === 'geraet' ? 'active' : '' %>" data-value="geraet">
            <span class="klasse-label">Gerät</span>
            <span class="form-hint" style="margin:0;text-align:center">Gerät auf dem Fahrzeug</span>
          </button>
        </div>
      </fieldset>
    </div>

    <!-- Schweregrad -->
    <div class="form-group">
      <fieldset class="schwere-fieldset">
        <legend class="form-label required">Schweregrad</legend>
        <div class="schwere-grid">
          <% [['klein','Klein','🟢','Kleinere Schäden, Fahrzeug einsatzbereit'],['normal','Normal','🟡','Eingeschränkte Funktion'],['totalausfall','Totalausfall','🔴','Fahrzeug nicht einsatzbereit']].forEach(([val,label,icon,hint]) => { %>
          <label class="schwere-option <%= old.schwere === val ? 'checked' : '' %>">
            <input type="radio" name="schwere" value="<%= val %>" <%= old.schwere === val ? 'checked' : '' %> required>
            <span class="schwere-icon"><%= icon %></span>
            <span class="schwere-label"><%= label %></span>
            <span class="form-hint" style="margin:0;text-align:center"><%= hint %></span>
          </label>
          <% }); %>
        </div>
      </fieldset>

      <div id="totalausfallHinweis" class="totalausfall-hinweis" style="display:<%= old.schwere === 'totalausfall' ? 'flex' : 'none' %>" role="alert">
        <span class="totalausfall-hinweis-icon">⚠️</span>
        <span>Bei Totalausfall zwingend Meldung an WAL unter <a href="tel:+492234956545" class="totalausfall-tel">02234-56545</a> machen!</span>
      </div>
    </div>

    <!-- Fehlerbeschreibung -->
    <div class="form-group">
      <label class="form-label required" for="fehlerBeschreibung">Fehlerbeschreibung</label>
      <input type="text" id="fehlerBeschreibung" name="fehlerBeschreibung" class="form-control"
        placeholder="Kurze, prägnante Beschreibung des Fehlers…"
        value="<%= old.fehlerBeschreibung || '' %>"
        required minlength="6" maxlength="200" autocomplete="off">

      <div id="similarBox" style="display:none;margin-top:var(--space-2);border-radius:var(--radius-md);overflow:hidden;border:1px solid var(--color-border);background:var(--color-surface)">
        <div id="similarLoading" style="display:none;padding:var(--space-3) var(--space-4);font-size:var(--text-xs);color:var(--color-text-muted);align-items:center;gap:var(--space-2)">
          <span style="display:inline-block;width:12px;height:12px;border:2px solid var(--color-border);border-top-color:var(--color-primary);border-radius:50%;animation:spin .7s linear infinite"></span>
          Suche…
        </div>
        <div id="similarList"></div>
      </div>

      <span class="form-hint">Mind. 6 Zeichen &ndash; wird mit Störungen dieses Fahrzeugs abgeglichen.</span>
    </div>

    <!-- Detailbeschreibung -->
    <div class="form-group">
      <label class="form-label" for="beschreibung">Detailbeschreibung</label>
      <textarea id="beschreibung" name="beschreibung" class="form-control" rows="4"
        placeholder="Wann aufgetreten? Unter welchen Umständen?…"
        maxlength="2000"><%= old.beschreibung || '' %></textarea>
    </div>

    <!-- Upload -->
    <div class="form-group">
      <label class="form-label">Fotos / Videos (max. <%= process.env.MAX_UPLOAD_MB || 8 %> MB pro Datei)</label>
      <div class="upload-area" id="uploadArea">
        <input type="file" id="attachments" name="attachments" multiple accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/quicktime" class="upload-input">
        <div class="upload-placeholder" id="uploadPlaceholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Klicken oder Dateien hierher ziehen</span>
          <span class="upload-hint">JPG, PNG, GIF, WebP, MP4, MOV &middot; max. 6 Dateien</span>
          <button type="button" class="btn btn-sm btn-ghost" id="uploadButton">Dateien auswählen…</button>
        </div>
        <div class="file-preview" id="filePreview" hidden></div>
      </div>
      <div id="uploadErrors" style="display:none;margin-top:var(--space-2);color:var(--color-error);font-size:var(--text-xs)"></div>
    </div>

    <div class="form-actions">
      <a href="/" class="btn btn-ghost" id="cancelBtn">Abbrechen</a>
      <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
        <span id="submitIdle" style="display:flex;align-items:center;gap:var(--space-2)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Störung melden
        </span>
        <span id="submitLoading" style="display:none;align-items:center;gap:var(--space-2)">
          <span style="display:inline-block;width:15px;height:15px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0" aria-hidden="true"></span>
          Wird gesendet…
        </span>
      </button>
    </div>
  </form>
</div>

<style>
@keyframes spin { to { transform: rotate(360deg); } }

.klasse-fieldset { border:none; padding:0; margin:0; min-inline-size:0; }
.klasse-grid { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-3); }
.klasse-option {
  display:flex; flex-direction:column; align-items:center; gap:var(--space-1);
  padding:var(--space-4) var(--space-3);
  border:2px solid var(--color-border); border-radius:var(--radius-lg);
  background:var(--color-surface); cursor:pointer;
  transition:border-color 180ms,background 180ms,box-shadow 180ms;
  font-size:var(--text-sm); color:var(--color-text); text-align:center;
}
.klasse-option:hover { border-color:var(--color-primary); background:var(--color-surface-offset); }
.klasse-option.active {
  border-color:var(--color-primary);
  background:color-mix(in oklch,var(--color-primary) 8%,var(--color-surface));
  box-shadow:0 0 0 3px oklch(from var(--color-primary) l c h / 0.15);
}
.klasse-label { font-weight:700; font-size:var(--text-base); }

.schwere-fieldset { border:none; padding:0; margin:0; min-inline-size:0; }
.schwere-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-3); justify-items:center; }
@media(max-width:480px) { .schwere-grid { grid-template-columns:1fr; justify-items:stretch; } }
.schwere-option {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:var(--space-2); padding:var(--space-4);
  background:var(--color-surface-2); border-radius:var(--radius-lg); cursor:pointer;
  text-align:center;
  transition:border-color var(--transition),background var(--transition),box-shadow var(--transition);
  border:2px solid transparent; box-shadow:var(--shadow-sm); width:100%;
}
.schwere-option input { position:absolute; opacity:0; width:0; height:0; }
.schwere-option:hover { border-color:var(--color-primary); }
.schwere-option.checked,
.schwere-option:has(input:checked) {
  border-color:var(--color-primary);
  background:color-mix(in oklch,var(--color-primary) 8%,var(--color-surface));
  box-shadow:var(--shadow-md);
}
.schwere-icon { font-size:1.75rem; line-height:1; }
.schwere-label { font-size:var(--text-xs); font-weight:600; }

.totalausfall-hinweis {
  display:flex; align-items:flex-start; gap:var(--space-2);
  margin-top:var(--space-3); padding:var(--space-3) var(--space-4);
  background:color-mix(in oklch,var(--color-error) 10%,var(--color-surface));
  border:1.5px solid color-mix(in oklch,var(--color-error) 40%,transparent);
  border-radius:var(--radius-md); color:var(--color-error);
  font-size:var(--text-sm); font-weight:600; line-height:1.5;
}
.totalausfall-hinweis-icon { font-size:1.1rem; flex-shrink:0; margin-top:1px; }
.totalausfall-tel { color:var(--color-error); font-weight:700; text-decoration:underline; text-underline-offset:2px; white-space:nowrap; }
.totalausfall-tel:hover { color:var(--color-error-hover); }

.similar-item {
  display:flex; align-items:center; gap:var(--space-3);
  padding:var(--space-3) var(--space-4); font-size:var(--text-xs);
  border-bottom:1px solid var(--color-divider); text-decoration:none; color:var(--color-text);
}
.similar-item:last-child { border-bottom:none; }
.similar-item:hover { background:var(--color-surface-offset); }
.similar-item.is-erledigt { opacity:0.6; background:var(--color-surface-offset-2); color:var(--color-text-muted); }
.similar-section-label {
  padding:var(--space-2) var(--space-4); font-size:var(--text-xs); font-weight:600;
  text-transform:uppercase; letter-spacing:0.05em; color:var(--color-text-faint);
  background:var(--color-surface-offset); border-bottom:1px solid var(--color-divider);
}
.similar-section-divider { height:4px; background:var(--color-surface-offset); border-top:1px solid var(--color-divider); border-bottom:1px solid var(--color-divider); }
.similar-ticket { font-family:monospace; font-size:10px; color:var(--color-text-muted); background:var(--color-surface-offset); border-radius:var(--radius-sm); padding:1px 5px; flex-shrink:0; white-space:nowrap; }
.similar-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.field-error { border-color:var(--color-error) !important; }
.field-error-msg { font-size:var(--text-xs); color:var(--color-error); margin-top:var(--space-1); display:block; }
#submitBtn:disabled { opacity:0.6; cursor:not-allowed; pointer-events:none; }
</style>

<script>
const MAX_FILE_BYTES = <%= parseInt(process.env.MAX_UPLOAD_MB || '8') %> * 1024 * 1024;
const MAX_FILES      = 6;
const MAX_NAME_LEN   = 200;
const ALLOWED_MIMES  = new Set(['image/jpeg','image/png','image/gif','image/webp','video/mp4','video/quicktime']);
const ALLOWED_EXTS   = new Set(['.jpg','.jpeg','.png','.gif','.webp','.mp4','.mov']);

const klasseInput   = document.getElementById('klasseInput');
const klasseButtons = document.querySelectorAll('.klasse-option');
klasseButtons.forEach(btn => {
  btn.addEventListener('click', () => {
    klasseButtons.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    klasseInput.value = btn.dataset.value;
  });
});

const totalausfallHinweis = document.getElementById('totalausfallHinweis');
document.querySelectorAll('.schwere-option').forEach(opt => {
  opt.addEventListener('click', () => {
    const val = opt.querySelector('input[type="radio"]').value;
    totalausfallHinweis.style.display = val === 'totalausfall' ? 'flex' : 'none';
  });
});

function checkMagicBytes(file) {
  return new Promise(resolve => {
    const reader = new FileReader();
    reader.onload = e => {
      const buf = new Uint8Array(e.target.result), mime = file.type;
      if (mime==='image/jpeg')  return resolve(buf[0]===0xFF&&buf[1]===0xD8&&buf[2]===0xFF);
      if (mime==='image/png')   return resolve(buf[0]===0x89&&buf[1]===0x50&&buf[2]===0x4E&&buf[3]===0x47);
      if (mime==='image/gif')   return resolve(buf[0]===0x47&&buf[1]===0x49&&buf[2]===0x46&&buf[3]===0x38);
      if (mime==='image/webp')  return resolve((buf[0]===0x52&&buf[1]===0x49&&buf[2]===0x46&&buf[3]===0x46)&&(buf[8]===0x57&&buf[9]===0x45&&buf[10]===0x42&&buf[11]===0x50));
      if (mime==='video/mp4'||mime==='video/quicktime') return resolve(buf[4]===0x66&&buf[5]===0x74&&buf[6]===0x79&&buf[7]===0x70);
      resolve(false);
    };
    reader.onerror = () => resolve(false);
    reader.readAsArrayBuffer(file.slice(0,12));
  });
}

async function validateFile(file) {
  const errors=[], name=file.name||'', ext=name.includes('.')?('.'+name.split('.').pop()).toLowerCase():'';
  if (name.length>MAX_NAME_LEN) errors.push(`"${name.slice(0,40)}…": Dateiname zu lang.`);
  if (/[\/\\<>:"|?\*\x00-\x1f]/.test(name)) errors.push(`"${name.slice(0,40)}": Ungültige Zeichen.`);
  if (!ALLOWED_MIMES.has(file.type)) { errors.push(`"${name.slice(0,40)}": Typ nicht erlaubt.`); return errors; }
  if (!ALLOWED_EXTS.has(ext))        { errors.push(`"${name.slice(0,40)}": Endung nicht erlaubt.`); return errors; }
  if (file.size>MAX_FILE_BYTES) errors.push(`"${name.slice(0,40)}": ${(file.size/1024/1024).toFixed(1)} MB (max ${MAX_FILE_BYTES/1024/1024} MB).`);
  if (!errors.length&&file.size>0&&!await checkMagicBytes(file)) errors.push(`"${name.slice(0,40)}": Inhalt stimmt nicht mit Typ überein.`);
  return errors;
}
async function validateFiles(fileList) {
  const allErrors=[],validFiles=[];
  for (const f of fileList) { const e=await validateFile(f); if (!e.length) validFiles.push(f); else allErrors.push(...e); }
  if (validFiles.length>MAX_FILES) { allErrors.push(`Max. ${MAX_FILES} Dateien.`); validFiles.splice(MAX_FILES); }
  return { valid:validFiles, errors:allErrors };
}

let storedFiles=new DataTransfer();
const area=document.getElementById('uploadArea'), input=document.getElementById('attachments');
const preview=document.getElementById('filePreview'), placeholder=document.getElementById('uploadPlaceholder');
const uploadButton=document.getElementById('uploadButton'), uploadErrors=document.getElementById('uploadErrors');
if (uploadButton) uploadButton.addEventListener('click', e=>{ e.stopPropagation(); input.click(); });
area.addEventListener('dragover', e=>{ e.preventDefault(); area.classList.add('drag-over'); });
area.addEventListener('dragleave', ()=>area.classList.remove('drag-over'));
area.addEventListener('drop', async e=>{ e.preventDefault(); area.classList.remove('drag-over'); await processNewFiles([...e.dataTransfer.files]); });
input.addEventListener('change', async ()=>{ await processNewFiles([...input.files]); });

async function processNewFiles(newFiles) {
  const { valid, errors } = await validateFiles([...storedFiles.files,...newFiles]);
  storedFiles=new DataTransfer(); valid.forEach(f=>storedFiles.items.add(f)); input.files=storedFiles.files;
  uploadErrors.style.display=errors.length?'block':'none';
  if (errors.length) uploadErrors.innerHTML=errors.map(e=>`⚠️ ${e}`).join('<br>');
  showPreview(storedFiles.files);
}
function showPreview(files) {
  preview.innerHTML='';
  if (!files.length) { preview.hidden=true; placeholder.hidden=false; return; }
  preview.hidden=false; placeholder.hidden=true;
  [...files].forEach((f,idx)=>{
    const item=document.createElement('div'); item.className='file-item';
    if (f.type.startsWith('image/')) { const img=document.createElement('img'); img.className='file-thumb'; img.alt=f.name; img.width=100; img.height=75; img.src=URL.createObjectURL(f); item.appendChild(img); }
    else { const icon=document.createElement('div'); icon.className='file-icon'; icon.textContent='🎦'; item.appendChild(icon); }
    const name=document.createElement('span'); name.className='file-name'; name.textContent=f.name; item.appendChild(name);
    const size=document.createElement('span'); size.className='file-size'; size.textContent=`${(f.size/1024).toFixed(0)} KB`; item.appendChild(size);
    const rm=document.createElement('button'); rm.type='button'; rm.className='btn btn-sm btn-ghost';
    rm.setAttribute('aria-label',`${f.name} entfernen`); rm.textContent='✕';
    rm.style.cssText='padding:2px 6px;font-size:11px;margin-left:auto;flex-shrink:0';
    rm.addEventListener('click',()=>removeFile(idx)); item.appendChild(rm); preview.appendChild(item);
  });
}
function removeFile(idx) {
  const next=new DataTransfer(); [...storedFiles.files].forEach((f,i)=>{ if(i!==idx) next.items.add(f); });
  storedFiles=next; input.files=storedFiles.files; showPreview(storedFiles.files);
}

const submitBtn=document.getElementById('submitBtn'), submitIdle=document.getElementById('submitIdle'), submitLoading=document.getElementById('submitLoading'), cancelBtn=document.getElementById('cancelBtn');
function setSubmitLoading(active) {
  submitBtn.disabled=active;
  submitIdle.style.display=active?'none':'flex'; submitLoading.style.display=active?'flex':'none';
  if (cancelBtn) { cancelBtn.style.pointerEvents=active?'none':''; cancelBtn.style.opacity=active?'0.4':''; }
}

const form=document.getElementById('stoerungForm'), errBox=document.getElementById('clientErrors'), errList=document.getElementById('clientErrorList');
function showFieldError(el,msg) {
  el.classList.add('field-error');
  let span=el.parentElement.querySelector('.field-error-msg');
  if (!span) { span=document.createElement('span'); span.className='field-error-msg'; el.after(span); }
  span.textContent=msg;
}
function clearFieldErrors() {
  document.querySelectorAll('.field-error').forEach(el=>el.classList.remove('field-error'));
  document.querySelectorAll('.field-error-msg').forEach(el=>el.remove());
}

form.addEventListener('submit', async e=>{
  e.preventDefault(); clearFieldErrors(); errBox.style.display='none'; errList.innerHTML='';
  const errors=[];
  const nameVal=document.getElementById('melderName').value.trim();
  if (!nameVal||nameVal.length<3) { errors.push('Name mind. 3 Zeichen.'); showFieldError(document.getElementById('melderName'),'Bitte Namen eingeben (mind. 3 Zeichen).'); }
  const handyVal=document.getElementById('melderHandy').value.trim(), mailVal=document.getElementById('melderMail').value.trim();
  if (!handyVal&&!mailVal) { errors.push('Bitte Handy oder E‑Mail angeben.'); showFieldError(document.getElementById('melderHandy'),'Handy oder E‑Mail erforderlich.'); }
  if (mailVal&&!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(mailVal)) { errors.push('E‑Mail ungültig.'); showFieldError(document.getElementById('melderMail'),'Ungültige E‑Mail-Adresse.'); }
  const fahrzeugVal=document.getElementById('fahrzeug').value;
  if (!fahrzeugVal) { errors.push('Bitte Fahrzeug auswählen.'); showFieldError(document.getElementById('fahrzeug'),'Fahrzeug auswählen.'); }
  const schwereVal=document.querySelector('input[name="schwere"]:checked');
  if (!schwereVal) { errors.push('Bitte Schweregrad auswählen.'); const fs=document.querySelector('.schwere-fieldset'); if(fs){let s=fs.querySelector('.field-error-msg'); if(!s){s=document.createElement('span');s.className='field-error-msg';fs.appendChild(s);} s.textContent='Schweregrad auswählen.';} }
  const fehlerVal=document.getElementById('fehlerBeschreibung').value.trim();
  if (!fehlerVal||fehlerVal.length<6) { errors.push('Fehlerbeschreibung mind. 6 Zeichen.'); showFieldError(document.getElementById('fehlerBeschreibung'),'Mind. 6 Zeichen.'); }
  if (storedFiles.files.length>0) { const {errors:fe}=await validateFiles([...storedFiles.files]); fe.forEach(f=>errors.push(f)); }
  if (errors.length) { errList.innerHTML=errors.map(e=>`<li>${e}</li>`).join(''); errBox.style.display='block'; errBox.scrollIntoView({behavior:'smooth',block:'center'}); return; }
  setSubmitLoading(true); setTimeout(()=>setSubmitLoading(false),60000); form.submit();
});

document.querySelectorAll('.schwere-option').forEach(opt=>{
  opt.addEventListener('click',()=>{ document.querySelectorAll('.schwere-option').forEach(o=>o.classList.remove('checked')); opt.classList.add('checked'); });
});

const fehlerInput=document.getElementById('fehlerBeschreibung'), fahrzeugSelect=document.getElementById('fahrzeug');
const similarBox=document.getElementById('similarBox'), similarLoading=document.getElementById('similarLoading'), similarList=document.getElementById('similarList');
const STATUS_META={ gesendet:{dot:'#22c55e',label:'Gesendet'}, bestaetigt:{dot:'#f59e0b',label:'Bestätigt'}, erledigt:{dot:'#9ca3af',label:'Erledigt'} };
let debounceTimer;
function checkSimilar() {
  clearTimeout(debounceTimer);
  const q=fehlerInput.value.trim();
  if (q.length<6) { similarBox.style.display='none'; return; }
  similarBox.style.display='block'; similarLoading.style.display='flex'; similarList.innerHTML='';
  debounceTimer=setTimeout(async()=>{
    const fahrzeug=fahrzeugSelect.value;
    try {
      const params=new URLSearchParams({q,includeErledigt:'1'});
      if (fahrzeug) params.set('fahrzeug',fahrzeug);
      const r=await fetch('/api/similar?'+params.toString()), data=await r.json();
      similarLoading.style.display='none';
      if (!data.length) { similarBox.style.display='none'; return; }
      const aktiv=data.filter(d=>d.status!=='erledigt'), erledigt=data.filter(d=>d.status==='erledigt');
      let html='';
      if (aktiv.length)    { html+=`<div class="similar-section-label">⚠️ Aktive Störungen (${aktiv.length})</div>`; aktiv.forEach(d=>{html+=renderItem(d);}); }
      if (erledigt.length) { if(aktiv.length) html+='<div class="similar-section-divider"></div>'; html+=`<div class="similar-section-label">✔️ Bereits erledigt (${erledigt.length})</div>`; erledigt.forEach(d=>{html+=renderItem(d);}); }
      similarList.innerHTML=html;
    } catch { similarLoading.style.display='none'; similarBox.style.display='none'; }
  },400);
}
function renderItem(d) {
  const meta=STATUS_META[d.status]||{dot:'#9ca3af',label:d.status}, erled=d.status==='erledigt';
  return `<a href="/stoerung/${encodeURIComponent(d.id)}" target="_blank" class="similar-item${erled?' is-erledigt':''}">
    <span class="similar-dot" style="background:${meta.dot}" title="${meta.label}"></span>
    <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${d.fehler}</span>
    <span class="similar-ticket">${d.id}</span>
  </a>`;
}
fehlerInput.addEventListener('input',checkSimilar);
fahrzeugSelect.addEventListener('change',checkSimilar);
</script>
