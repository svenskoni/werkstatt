<div class="form-container">
  <div class="form-header">
    <a href="/" class="back-link">← Dashboard</a>
    <h1 class="page-title">🚨 Neue Störung melden</h1>
  </div>

  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error" role="alert">
      <ul class="error-list">
        <% errors.forEach(e => { %><li><%= e %></li><% }); %>
      </ul>
    </div>
  <% } %>

  <!-- Inline-Validierungsfehler (clientseitig) -->
  <div id="clientErrors" class="alert alert-error" role="alert" style="display:none">
    <ul id="clientErrorList" class="error-list"></ul>
  </div>

  <form class="stoerung-form" id="stoerungForm" action="/stoerung/neu" method="POST" enctype="multipart/form-data" novalidate>

    <!-- Melderdaten -->
    <div class="form-group">
      <label class="form-label required" for="melderName">Name des Melders</label>
      <input type="text" id="melderName" name="melderName" class="form-control"
        placeholder="Vor- und Nachname" value="<%= old.melderName || '' %>"
        required minlength="3" maxlength="100" autocomplete="name">
    </div>

    <div class="form-group">
      <label class="form-label required" for="melderHandy">Handy</label>
      <input type="tel" id="melderHandy" name="melderHandy" class="form-control"
        placeholder="Mobilnummer" value="<%= old.melderHandy || '' %>"
        minlength="5" maxlength="40" autocomplete="tel">
      <span class="form-hint">Handy oder E‑Mail muss ausgefüllt sein.</span>
    </div>

    <div class="form-group">
      <label class="form-label" for="melderMail">E‑Mail</label>
      <input type="email" id="melderMail" name="melderMail" class="form-control"
        placeholder="E‑Mailadresse" value="<%= old.melderMail || '' %>"
        maxlength="120" autocomplete="email">
    </div>

    <!-- Benachrichtigung opt-in -->
    <div class="form-group" id="benachrichtigungGroup" style="display:none">
      <div class="toggle-card" id="benachrichtigungToggle" role="checkbox" aria-checked="false" tabindex="0"
        style="display:flex;align-items:center;gap:var(--space-3);padding:var(--space-4);border-radius:var(--radius-md);border:2px solid var(--color-border);cursor:pointer;background:var(--color-surface);transition:border-color var(--transition-interactive),background var(--transition-interactive)">
        <div style="font-size:22px;line-height:1">🔔</div>
        <div style="flex:1">
          <div style="font-weight:600;font-size:var(--text-sm)">Ich möchte bei Statusänderungen informiert werden</div>
          <div style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:2px">Sie erhalten eine E-Mail wenn sich der Status ändert</div>
        </div>
        <div class="toggle-check" style="width:22px;height:22px;border-radius:50%;border:2px solid var(--color-border);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0"></div>
      </div>
      <input type="hidden" name="melderBenachrichtigung" id="melderBenachrichtigungInput" value="0">
    </div>

    <!-- Fahrzeug -->
    <div class="form-group">
      <label class="form-label required" for="fahrzeug">Fahrzeug</label>
      <select id="fahrzeug" name="fahrzeug" class="form-control form-select" required>
        <option value="" disabled <%= !old.fahrzeug ? 'selected' : '' %>>Fahrzeug wählen…</option>
        <% VEHICLES.forEach(v => { %>
          <option value="<%= v %>" <%= old.fahrzeug === v ? 'selected' : '' %>><%= v %></option>
        <% }); %>
      </select>
    </div>

    <!-- Schweregrad -->
    <div class="form-group">
      <fieldset class="schwere-fieldset">
        <legend class="form-label required">Schweregrad</legend>
        <div class="schwere-grid">
          <% [['klein','Klein','🟢','Kleinere Schäden, Fahrzeug einsatzbereit'],['normal','Normal','🟡','Eingeschränkte Funktion'],['schwer','Schwer','🟠','Erheblicher Schaden'],['totalausfall','Totalausfall','🔴','Fahrzeug nicht einsatzbereit']].forEach(([val,label,icon,hint]) => { %>
          <label class="schwere-option <%= old.schwere === val ? 'checked' : '' %>">
            <input type="radio" name="schwere" value="<%= val %>" <%= old.schwere === val ? 'checked' : '' %> required>
            <span class="schwere-icon"><%= icon %></span>
            <span class="schwere-label"><%= label %></span>
            <span class="form-hint" style="margin:0;text-align:center"><%= hint %></span>
          </label>
          <% }); %>
        </div>
      </fieldset>
    </div>

    <!-- Fehlerbeschreibung -->
    <div class="form-group">
      <label class="form-label required" for="fehlerBeschreibung">Fehlerbeschreibung</label>
      <input type="text" id="fehlerBeschreibung" name="fehlerBeschreibung" class="form-control"
        placeholder="Kurze, prägnante Beschreibung des Fehlers…"
        value="<%= old.fehlerBeschreibung || '' %>"
        required minlength="6" maxlength="200" autocomplete="off">

      <div id="similarBox" style="display:none;margin-top:var(--space-2);border-radius:var(--radius-md);overflow:hidden;border:1px solid var(--color-border);background:var(--color-surface)">
        <div id="similarLoading" style="display:none;padding:var(--space-3) var(--space-4);font-size:var(--text-xs);color:var(--color-text-muted);align-items:center;gap:var(--space-2)">
          <span style="display:inline-block;width:12px;height:12px;border:2px solid var(--color-border);border-top-color:var(--color-primary);border-radius:50%;animation:spin .7s linear infinite"></span>
          Suche…
        </div>
        <div id="similarList"></div>
      </div>

      <span class="form-hint">Mind. 6 Zeichen &ndash; wird mit Störungen dieses Fahrzeugs abgeglichen.</span>
    </div>

    <!-- Detailbeschreibung -->
    <div class="form-group">
      <label class="form-label" for="beschreibung">Detailbeschreibung</label>
      <textarea id="beschreibung" name="beschreibung" class="form-control" rows="4"
        placeholder="Wann aufgetreten? Unter welchen Umständen?…"
        maxlength="2000"><%= old.beschreibung || '' %></textarea>
    </div>

    <!-- Upload -->
    <div class="form-group">
      <label class="form-label">Fotos / Videos (max. <%= process.env.MAX_UPLOAD_MB || 8 %> MB pro Datei)</label>
      <div class="upload-area" id="uploadArea">
        <input type="file" id="attachments" name="attachments" multiple accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/quicktime" class="upload-input">
        <div class="upload-placeholder" id="uploadPlaceholder">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Klicken oder Dateien hierher ziehen</span>
          <span class="upload-hint">JPG, PNG, GIF, WebP, MP4, MOV &middot; max. 6 Dateien</span>
          <button type="button" class="btn btn-sm btn-ghost" id="uploadButton">Dateien auswählen…</button>
        </div>
        <div class="file-preview" id="filePreview" hidden></div>
      </div>
      <div id="uploadErrors" style="display:none;margin-top:var(--space-2);color:var(--color-error);font-size:var(--text-xs)"></div>
    </div>

    <div class="form-actions">
      <a href="/" class="btn btn-ghost">Abbrechen</a>
      <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Störung melden
      </button>
    </div>
  </form>
</div>

<style>
@keyframes spin { to { transform: rotate(360deg); } }
.similar-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-xs);
  border-bottom: 1px solid var(--color-divider);
  text-decoration: none;
  color: var(--color-text);
}
.similar-item:last-child { border-bottom: none; }
.similar-item:hover { background: var(--color-surface-offset); }
.similar-item.is-erledigt {
  opacity: 0.6;
  background: var(--color-surface-offset-2);
  color: var(--color-text-muted);
}
.similar-section-label {
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-text-faint);
  background: var(--color-surface-offset);
  border-bottom: 1px solid var(--color-divider);
}
.similar-section-divider {
  height: 4px;
  background: var(--color-surface-offset);
  border-top: 1px solid var(--color-divider);
  border-bottom: 1px solid var(--color-divider);
}
.similar-ticket {
  font-family: monospace;
  font-size: 10px;
  color: var(--color-text-muted);
  background: var(--color-surface-offset);
  border-radius: var(--radius-sm);
  padding: 1px 5px;
  flex-shrink: 0;
  white-space: nowrap;
}
.similar-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.field-error {
  border-color: var(--color-error) !important;
}
.field-error-msg {
  font-size: var(--text-xs);
  color: var(--color-error);
  margin-top: var(--space-1);
  display: block;
}
</style>

<script>
// ═══════════════════════════════════════════════════════════════
// KONSTANTEN
// ═══════════════════════════════════════════════════════════════
const MAX_FILE_BYTES = <%= parseInt(process.env.MAX_UPLOAD_MB || '8') %> * 1024 * 1024;
const MAX_FILES      = 6;
const MAX_NAME_LEN   = 200;

// Erlaubte MIME-Typen (Whitelist)
const ALLOWED_MIMES = new Set([
  'image/jpeg', 'image/png', 'image/gif', 'image/webp',
  'video/mp4', 'video/quicktime',
]);

// Erlaubte Dateiendungen (Whitelist, lowercase)
const ALLOWED_EXTS = new Set(['.jpg','.jpeg','.png','.gif','.webp','.mp4','.mov']);

// Magic-Bytes Signaturen (Hex-Präfixe)
const MAGIC = [
  { mime: 'image/jpeg',     bytes: [0xFF,0xD8,0xFF] },
  { mime: 'image/png',      bytes: [0x89,0x50,0x4E,0x47] },
  { mime: 'image/gif',      bytes: [0x47,0x49,0x46,0x38] },
  { mime: 'image/webp',     bytes: null, webp: true },   // RIFF....WEBP
  { mime: 'video/mp4',      bytes: null, mp4: true },    // ftyp box offset 4
  { mime: 'video/quicktime',bytes: null, mov: true },    // ftyp/wide/moov
];

// ═══════════════════════════════════════════════════════════════
// MAGIC-BYTES PRÜFUNG
// Liest die ersten 12 Bytes einer Datei und vergleicht mit
// bekannten Signaturen. Gibt Promise<boolean> zurück.
// ═══════════════════════════════════════════════════════════════
function checkMagicBytes(file) {
  return new Promise(resolve => {
    const reader = new FileReader();
    reader.onload = e => {
      const buf  = new Uint8Array(e.target.result);
      const mime = file.type;

      // JPEG: FF D8 FF
      if (mime === 'image/jpeg') {
        resolve(buf[0]===0xFF && buf[1]===0xD8 && buf[2]===0xFF);
        return;
      }
      // PNG: 89 50 4E 47
      if (mime === 'image/png') {
        resolve(buf[0]===0x89 && buf[1]===0x50 && buf[2]===0x4E && buf[3]===0x47);
        return;
      }
      // GIF: 47 49 46 38 (GIF8)
      if (mime === 'image/gif') {
        resolve(buf[0]===0x47 && buf[1]===0x49 && buf[2]===0x46 && buf[3]===0x38);
        return;
      }
      // WebP: RIFF????WEBP
      if (mime === 'image/webp') {
        const riff = buf[0]===0x52 && buf[1]===0x49 && buf[2]===0x46 && buf[3]===0x46;
        const webp = buf[8]===0x57 && buf[9]===0x45 && buf[10]===0x42 && buf[11]===0x50;
        resolve(riff && webp);
        return;
      }
      // MP4 / MOV: ftyp-Box an Byte 4 (4 Bytes: 66 74 79 70)
      if (mime === 'video/mp4' || mime === 'video/quicktime') {
        const ftyp = buf[4]===0x66 && buf[5]===0x74 && buf[6]===0x79 && buf[7]===0x70;
        resolve(ftyp);
        return;
      }
      resolve(false);
    };
    reader.onerror = () => resolve(false);
    reader.readAsArrayBuffer(file.slice(0, 12));
  });
}

// ═══════════════════════════════════════════════════════════════
// EINZELNE DATEI VALIDIEREN
// Gibt Array mit Fehlermeldungen zurück (leer = OK)
// ═══════════════════════════════════════════════════════════════
async function validateFile(file) {
  const errors = [];
  const name   = file.name || '';
  const ext    = name.includes('.') ? ('.' + name.split('.').pop()).toLowerCase() : '';

  // 1. Dateiname-Länge
  if (name.length > MAX_NAME_LEN) {
    errors.push(`"${name.slice(0,40)}…": Dateiname zu lang (max. ${MAX_NAME_LEN} Zeichen).`);
  }

  // 2. Unerlaubte Zeichen im Dateinamen (Schutz vor Path-Traversal)
  if (/[\/\\<>:"\|\?\*\x00-\x1f]/.test(name)) {
    errors.push(`"${name.slice(0,40)}": Dateiname enthält ungültige Zeichen.`);
  }

  // 3. MIME-Typ Whitelist
  if (!ALLOWED_MIMES.has(file.type)) {
    errors.push(`"${name.slice(0,40)}": Dateityp "${file.type}" ist nicht erlaubt.`);
    return errors; // Weitere Prüfungen sinnlos
  }

  // 4. Dateiendung Whitelist + Übereinstimmung mit MIME
  if (!ALLOWED_EXTS.has(ext)) {
    errors.push(`"${name.slice(0,40)}": Dateiendung "${ext}" ist nicht erlaubt.`);
    return errors;
  }

  // 5. Dateigröße
  if (file.size > MAX_FILE_BYTES) {
    const mb = (file.size / 1024 / 1024).toFixed(1);
    const max = (MAX_FILE_BYTES / 1024 / 1024).toFixed(0);
    errors.push(`"${name.slice(0,40)}": Datei ist ${mb} MB groß (max. ${max} MB).`);
  }

  // 6. Magic-Bytes prüfen (nur wenn MIME + Ext OK und Datei nicht leer)
  if (errors.length === 0 && file.size > 0) {
    const magicOk = await checkMagicBytes(file);
    if (!magicOk) {
      errors.push(`"${name.slice(0,40)}": Dateiinhalt stimmt nicht mit dem Dateityp überein (mögliche Manipulation).`);
    }
  }

  return errors;
}

// ═══════════════════════════════════════════════════════════════
// DATEIEN VALIDIEREN & FILTERN
// Gibt { valid: File[], errors: string[] } zurück
// ═══════════════════════════════════════════════════════════════
async function validateFiles(fileList) {
  const allErrors = [];
  const validFiles = [];

  for (const file of fileList) {
    const errs = await validateFile(file);
    if (errs.length === 0) {
      validFiles.push(file);
    } else {
      allErrors.push(...errs);
    }
  }

  if (validFiles.length > MAX_FILES) {
    allErrors.push(`Maximal ${MAX_FILES} Dateien erlaubt. Die letzten ${validFiles.length - MAX_FILES} wurden entfernt.`);
    validFiles.splice(MAX_FILES);
  }

  return { valid: validFiles, errors: allErrors };
}

// ═══════════════════════════════════════════════════════════════
// GESPEICHERTE DATEIEN (bleiben bei Validierungsfehlern erhalten)
// ═══════════════════════════════════════════════════════════════
let storedFiles = new DataTransfer();

// ═══════════════════════════════════════════════════════════════
// UPLOAD UI
// ═══════════════════════════════════════════════════════════════
const area         = document.getElementById('uploadArea');
const input        = document.getElementById('attachments');
const preview      = document.getElementById('filePreview');
const placeholder  = document.getElementById('uploadPlaceholder');
const uploadButton = document.getElementById('uploadButton');
const uploadErrors = document.getElementById('uploadErrors');

if (uploadButton) uploadButton.addEventListener('click', e => { e.stopPropagation(); input.click(); });

area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('drag-over'); });
area.addEventListener('dragleave', () => area.classList.remove('drag-over'));
area.addEventListener('drop', async e => {
  e.preventDefault();
  area.classList.remove('drag-over');
  await processNewFiles([...e.dataTransfer.files]);
});

input.addEventListener('change', async () => {
  await processNewFiles([...input.files]);
});

async function processNewFiles(newFiles) {
  const combined = [...storedFiles.files, ...newFiles];
  const { valid, errors } = await validateFiles(combined);

  // Gespeicherte Dateien aktualisieren
  storedFiles = new DataTransfer();
  valid.forEach(f => storedFiles.items.add(f));
  input.files = storedFiles.files;

  // Upload-Fehler anzeigen
  if (errors.length) {
    uploadErrors.innerHTML = errors.map(e => `⚠️ ${e}`).join('<br>');
    uploadErrors.style.display = 'block';
  } else {
    uploadErrors.style.display = 'none';
  }

  showPreview(storedFiles.files);
}

function showPreview(files) {
  preview.innerHTML = '';
  if (!files.length) { preview.hidden = true; placeholder.hidden = false; return; }
  preview.hidden = false; placeholder.hidden = true;
  [...files].forEach((f, idx) => {
    const item = document.createElement('div'); item.className = 'file-item';
    if (f.type.startsWith('image/')) {
      const img = document.createElement('img');
      img.className = 'file-thumb'; img.alt = f.name; img.width = 100; img.height = 75;
      img.src = URL.createObjectURL(f); item.appendChild(img);
    } else {
      const icon = document.createElement('div'); icon.className = 'file-icon'; icon.textContent = '🎬'; item.appendChild(icon);
    }
    const name = document.createElement('span'); name.className = 'file-name'; name.textContent = f.name; item.appendChild(name);
    const size = document.createElement('span'); size.className = 'file-size';
    const mb = (f.size / 1024 / 1024).toFixed(1);
    size.textContent = `${(f.size/1024).toFixed(0)} KB`;
    item.appendChild(size);

    // Entfernen-Button
    const rm = document.createElement('button');
    rm.type = 'button'; rm.className = 'btn btn-sm btn-ghost';
    rm.setAttribute('aria-label', `${f.name} entfernen`);
    rm.textContent = '✕';
    rm.style.cssText = 'padding:2px 6px;font-size:11px;margin-left:auto;flex-shrink:0';
    rm.addEventListener('click', () => removeFile(idx));
    item.appendChild(rm);

    preview.appendChild(item);
  });
}

function removeFile(idx) {
  const next = new DataTransfer();
  [...storedFiles.files].forEach((f, i) => { if (i !== idx) next.items.add(f); });
  storedFiles = next;
  input.files = storedFiles.files;
  showPreview(storedFiles.files);
}

// ═══════════════════════════════════════════════════════════════
// FORMULAR-VALIDIERUNG (clientseitig, verhindert Seitenneulade)
// ═══════════════════════════════════════════════════════════════
const form        = document.getElementById('stoerungForm');
const errBox      = document.getElementById('clientErrors');
const errList     = document.getElementById('clientErrorList');

function showFieldError(inputEl, msg) {
  inputEl.classList.add('field-error');
  let span = inputEl.parentElement.querySelector('.field-error-msg');
  if (!span) { span = document.createElement('span'); span.className = 'field-error-msg'; inputEl.after(span); }
  span.textContent = msg;
}
function clearFieldErrors() {
  document.querySelectorAll('.field-error').forEach(el => el.classList.remove('field-error'));
  document.querySelectorAll('.field-error-msg').forEach(el => el.remove());
}

form.addEventListener('submit', async e => {
  e.preventDefault();
  clearFieldErrors();
  errBox.style.display = 'none';
  errList.innerHTML = '';

  const errors = [];

  // Name
  const nameVal = document.getElementById('melderName').value.trim();
  if (!nameVal || nameVal.length < 3) {
    errors.push('Name des Melders ist erforderlich (mind. 3 Zeichen).');
    showFieldError(document.getElementById('melderName'), 'Bitte Namen eingeben (mind. 3 Zeichen).');
  }

  // Handy oder Mail
  const handyVal = document.getElementById('melderHandy').value.trim();
  const mailVal  = document.getElementById('melderMail').value.trim();
  if (!handyVal && !mailVal) {
    errors.push('Bitte Handy oder E‑Mail angeben.');
    showFieldError(document.getElementById('melderHandy'), 'Handy oder E‑Mail erforderlich.');
  }
  if (mailVal && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(mailVal)) {
    errors.push('E‑Mail-Adresse ist ungültig.');
    showFieldError(document.getElementById('melderMail'), 'Ungültige E‑Mail-Adresse.');
  }

  // Fahrzeug
  const fahrzeugVal = document.getElementById('fahrzeug').value;
  if (!fahrzeugVal) {
    errors.push('Bitte ein Fahrzeug auswählen.');
    showFieldError(document.getElementById('fahrzeug'), 'Fahrzeug auswählen.');
  }

  // Schweregrad
  const schwereVal = document.querySelector('input[name="schwere"]:checked');
  if (!schwereVal) {
    errors.push('Bitte einen Schweregrad auswählen.');
    const fieldset = document.querySelector('.schwere-fieldset');
    if (fieldset) {
      let span = fieldset.querySelector('.field-error-msg');
      if (!span) { span = document.createElement('span'); span.className = 'field-error-msg'; fieldset.appendChild(span); }
      span.textContent = 'Schweregrad auswählen.';
    }
  }

  // Fehlerbeschreibung
  const fehlerVal = document.getElementById('fehlerBeschreibung').value.trim();
  if (!fehlerVal || fehlerVal.length < 6) {
    errors.push('Fehlerbeschreibung ist erforderlich (mind. 6 Zeichen).');
    showFieldError(document.getElementById('fehlerBeschreibung'), 'Bitte Fehlerbeschreibung eingeben (mind. 6 Zeichen).');
  }

  // Upload-Dateien erneut prüfen (falls jemand JS-Tricks versucht)
  if (storedFiles.files.length > 0) {
    const { errors: fileErrs } = await validateFiles([...storedFiles.files]);
    fileErrs.forEach(fe => errors.push(fe));
  }

  if (errors.length) {
    errList.innerHTML = errors.map(e => `<li>${e}</li>`).join('');
    errBox.style.display = 'block';
    errBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  // Alles OK → absenden
  form.submit();
});

// ═══════════════════════════════════════════════════════════════
// SCHWEREGRAD
// ═══════════════════════════════════════════════════════════════
document.querySelectorAll('.schwere-option').forEach(opt => {
  opt.addEventListener('click', () => {
    document.querySelectorAll('.schwere-option').forEach(o => o.classList.remove('checked'));
    opt.classList.add('checked');
  });
});

// ═══════════════════════════════════════════════════════════════
// ÄHNLICHE FEHLER
// ═══════════════════════════════════════════════════════════════
const fehlerInput    = document.getElementById('fehlerBeschreibung');
const fahrzeugSelect = document.getElementById('fahrzeug');
const similarBox     = document.getElementById('similarBox');
const similarLoading = document.getElementById('similarLoading');
const similarList    = document.getElementById('similarList');

const STATUS_META = {
  gesendet:   { dot: '#22c55e', label: 'Gesendet' },
  bestaetigt: { dot: '#f59e0b', label: 'Bestätigt' },
  erledigt:   { dot: '#9ca3af', label: 'Erledigt' },
};

let debounceTimer;
function checkSimilar() {
  clearTimeout(debounceTimer);
  const q = fehlerInput.value.trim();
  if (q.length < 6) { similarBox.style.display = 'none'; return; }
  similarBox.style.display = 'block';
  similarLoading.style.display = 'flex';
  similarList.innerHTML = '';
  debounceTimer = setTimeout(async () => {
    const fahrzeug = fahrzeugSelect.value;
    try {
      const params = new URLSearchParams({ q, includeErledigt: '1' });
      if (fahrzeug) params.set('fahrzeug', fahrzeug);
      const r    = await fetch('/api/similar?' + params.toString());
      const data = await r.json();
      similarLoading.style.display = 'none';
      if (!data.length) { similarBox.style.display = 'none'; return; }
      const aktiv    = data.filter(d => d.status !== 'erledigt');
      const erledigt = data.filter(d => d.status === 'erledigt');
      let html = '';
      if (aktiv.length) {
        html += `<div class="similar-section-label">⚠️ Aktive Störungen (${aktiv.length})</div>`;
        aktiv.forEach(d => { html += renderItem(d); });
      }
      if (erledigt.length) {
        if (aktiv.length) html += `<div class="similar-section-divider"></div>`;
        html += `<div class="similar-section-label">✔️ Bereits erledigt (${erledigt.length})</div>`;
        erledigt.forEach(d => { html += renderItem(d); });
      }
      similarList.innerHTML = html;
    } catch { similarLoading.style.display = 'none'; similarBox.style.display = 'none'; }
  }, 400);
}

function renderItem(d) {
  const meta  = STATUS_META[d.status] || { dot: '#9ca3af', label: d.status };
  const erled = d.status === 'erledigt';
  return `<a href="/stoerung/${encodeURIComponent(d.id)}" target="_blank" class="similar-item${erled ? ' is-erledigt' : ''}">
    <span class="similar-dot" style="background:${meta.dot}" title="${meta.label}"></span>
    <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${d.fehler}</span>
    <span class="similar-ticket">${d.id}</span>
  </a>`;
}

fehlerInput.addEventListener('input', checkSimilar);
fahrzeugSelect.addEventListener('change', checkSimilar);

// ═══════════════════════════════════════════════════════════════
// BENACHRICHTIGUNGS-TOGGLE
// ═══════════════════════════════════════════════════════════════
const mailInput  = document.getElementById('melderMail');
const benGrp     = document.getElementById('benachrichtigungGroup');
const benToggle  = document.getElementById('benachrichtigungToggle');
const benInput   = document.getElementById('melderBenachrichtigungInput');
const benCheck   = benToggle.querySelector('.toggle-check');
let benActive    = false;

function updateBenVisible() {
  const hasMail = mailInput.value.trim().includes('@');
  benGrp.style.display = hasMail ? 'block' : 'none';
  if (!hasMail) { benActive = false; benInput.value = '0'; applyBenState(); }
}
function applyBenState() {
  if (benActive) {
    benToggle.style.borderColor = 'var(--color-primary)';
    benToggle.style.background  = 'oklch(from var(--color-primary) l c h / 0.07)';
    benCheck.textContent = '✓'; benCheck.style.borderColor = 'var(--color-primary)';
    benCheck.style.color = 'var(--color-primary)'; benCheck.style.fontWeight = 'bold';
    benToggle.setAttribute('aria-checked', 'true');
  } else {
    benToggle.style.borderColor = 'var(--color-border)';
    benToggle.style.background  = 'var(--color-surface)';
    benCheck.textContent = ''; benCheck.style.borderColor = 'var(--color-border)';
    benToggle.setAttribute('aria-checked', 'false');
  }
}
benToggle.addEventListener('click', () => { benActive = !benActive; benInput.value = benActive ? '1' : '0'; applyBenState(); });
benToggle.addEventListener('keydown', e => { if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); benToggle.click(); } });
mailInput.addEventListener('input', updateBenVisible);
updateBenVisible();
</script>
